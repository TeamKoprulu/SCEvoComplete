    <CActorAction id="InterceptorSCBWWeaponAlt@Action" parent="GenericAttackBase">
        <On Terms="EffectActionCommence" Target="::HostImpactInternal" Send="Signal Impact"/>
        <On Terms="Effect.InterceptorSCBWWeaponAlt@CP.Start; At Caster" Send="Create"/>
        <On Terms="Effect.InterceptorSCBWWeaponAlt@Damage.Start; At Caster; FromEffectTreeDescendant" Send="ActionDamage"/>
        <On Terms="Effect.InterceptorSCBWWeaponAlt@Damage.Stop; At Caster; FromEffectTreeDescendant" Send="ActionDamagePhysics"/>
        <LaunchAttachQuery Methods="AMFilterWeapon"/>
        <LaunchAssets Sound="InterceptorSCBWWeapon@Launch"/>
        <Beam value="InterceptorSCBWWeaponAlt@Beam"/>
        <BeamScope value="Caster"/>
        <ImpactSite value="GenericAttackImpactSiteWhiff"/>
        <ImpactMap index="None" Model="InterceptorSCBWWeapon@Impact" Sound="InterceptorSCBWWeapon@Impact"/>
        <ImpactModel value="InterceptorAttackImpactModel"/>
        <ImpactModelReaction value="GenericAttackImpactModelReactionWhiff"/>
        <DamagePhysics Name="InterceptorSCBWWeaponAlt@Impact" MatchKeys="Basic" Physics="InterceptorAttackDeathForce"/>
        <DamagePhysics Name="InterceptorSCBWWeaponAlt@Impact" MatchKeys="BasicAir" Physics="InterceptorAttackAirDeathForce"/>
        <ActionFlags index="ImpactMonitorsTeleports" value="1"/>
    </CActorAction>
    <CActorBeamSimple id="InterceptorSCBWWeaponAlt@Beam">
        <Macros value="ActionTargetTeleportDestroy"/>
        <Flags index="SuppressSaveLoad" value="1"/>
        <On Terms="ActorCreation" Send="AnimBracketStart BSD Birth Stand Death ContentPlayOnce"/>
        <On Terms="ActorOrphan" Send="Destroy"/>
        <On Terms="AnimBracketState.*.AfterClosing; AnimName BSD" Send="Destroy"/>
        <Model value="InterceptorSCBWWeapon@Beam"/>
    </CActorBeamSimple>
