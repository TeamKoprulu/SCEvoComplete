<?xml version="1.0" encoding="utf-8"?>
<Catalog>
    <CActorUnit id="NexusSCBW">
        <PlacementActorModel value="NexusSCBW@PlacementModel"/>
        <On Terms="ActorCreation" Target="::external.ShieldBatterySCBWMatrixHarmonics@ActorList" Send="Signal NexusAddMe"/>
        <On Terms="ActorDestruction" Target="::external.ShieldBatterySCBWMatrixHarmonics@ActorList" Send="Signal NexusRemoveMe"/>
        <On Terms="Signal.*.DestroyMatrixHarmonicsRange" Target="ShieldBatterySCBWMatrixHarmonics@Range" Send="Destroy"/>
    </CActorUnit>
    <CActorModel id="NexusSCBW@PlacementModel" parent="PlacementModel">
        <On Terms="ActorCreation" Send="Create ShieldBatterySCBWMatrixHarmonics@Range"/>
        <Model value="NexusPlacementModel"/>
    </CActorModel>
    <CActorUnit id="DevourerSCBW">
        <On index="65" Terms="WeaponStart.*.AttackStart" Send="AnimBracketStart Attack Attack"/>
    </CActorUnit>
    <CActorAction id="DevourerSCBWWeapon@Action">
