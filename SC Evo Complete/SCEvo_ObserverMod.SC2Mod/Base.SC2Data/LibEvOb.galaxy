// Triggers
//--------------------------------------------------------------------------------------------------
// Trigger: GameHeart - Initialization
//--------------------------------------------------------------------------------------------------
bool libEvOb_gt_GameHeartInitialization_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_i;
    unit lv_unit;
    int lv_controller;

    // Automatic Variable Declarations
    playergroup autoAA0F1A58_g;
    const int auto3843C4AA_ae = 15;
    const int auto3843C4AA_ai = 1;
    unitgroup autoBAD71A13_g;
    int autoBAD71A13_u;

    // Variable Initialization

    // Actions
    if (!runActions) {
        return true;
    }

    if (((PlayerType(libEvOb_gv_obsID) == c_playerTypeUser) || (PlayerType(libEvOb_gv_obsID) == c_playerTypeComputer))) {
        TriggerEnable(libEvOb_gt_MapNotificationsDrop, false);
        TriggerEnable(libEvOb_gt_MapNotificationsScannerSweep, false);
        TriggerEnable(libEvOb_gt_GameHeartRevealDebrisFromDestructubleTowers, false);
        return false;
    }

    UIUnitColorStyleOverride(libEvOb_gv_obs, c_unitColorStyleNormal);
    autoAA0F1A58_g = libEvOb_gv_initial_Active_Players;
    lv_i = -1;
    while (true) {
        lv_i = PlayerGroupNextPlayer(autoAA0F1A58_g, lv_i);
        if (lv_i < 0) { break; }
        libNtve_gf_SetAllianceOneWay(libEvOb_gv_obsID, lv_i, libNtve_ge_AllianceSetting_Neutral);
        PlayerSetAlliance(lv_i, c_allianceIdDefeat, libEvOb_gv_obsID, false);
        PlayerSetAlliance(lv_i, c_allianceIdPassive, libEvOb_gv_obsID, true);
        PlayerSetAlliance(lv_i, c_allianceIdControl, libEvOb_gv_obsID, true);
        PlayerSetAlliance(lv_i, c_allianceIdVision, libEvOb_gv_obsID, true);
        libNtve_gf_SetUpgradeLevelForPlayer(lv_i, "GameHeartActive", 1);
    }
    lv_i = 0;
    for ( ; ( (auto3843C4AA_ai >= 0 && lv_i <= auto3843C4AA_ae) || (auto3843C4AA_ai < 0 && lv_i >= auto3843C4AA_ae) ) ; lv_i += auto3843C4AA_ai ) {
        lv_controller = PlayerType(lv_i);
        if (((lv_controller == c_playerTypeNeutral) || (lv_controller == c_playerTypeHostile) || (lv_controller == c_playerTypeNone))) {
            autoBAD71A13_g = UnitGroup(null, lv_i, RegionEntireMap(), UnitFilter(0, 0, 0, 0), 0);
            autoBAD71A13_u = UnitGroupCount(autoBAD71A13_g, c_unitCountAll);
            for (;; autoBAD71A13_u -= 1) {
                lv_unit = UnitGroupUnitFromEnd(autoBAD71A13_g, autoBAD71A13_u);
                if (lv_unit == null) { break; }
                UnitBehaviorAddPlayer(lv_unit, "AHLI_Reveal", libEvOb_gv_obsID, 1);
            }
        }

    }
    TriggerExecute(libEvOb_gt_GraphsInitialization, true, false);
    TriggerExecute(libEvOb_gt_LabelsInitialization, true, false);
    TriggerExecute(libEvOb_gt_UpgradeNotificationsInitialization, true, false);
    TriggerExecute(libEvOb_gt_WorkersKilledNotificationsInitialization, true, false);
    TriggerExecute(libEvOb_gt_ObserverUiAssistInitialization, true, false);
    TriggerExecute(libEvOb_gt_MinimapFrustumInitialization, true, false);
    TriggerExecute(libEvOb_gt_BattleReportInitialization, true, false);

    return true;
}

//--------------------------------------------------------------------------------------------------
void libEvOb_gt_GameHeartInitialization_Init () {
    libEvOb_gt_GameHeartInitialization = TriggerCreate("libEvOb_gt_GameHeartInitialization_Func");
    TriggerAddEventMapInit(libEvOb_gt_GameHeartInitialization);
}

