//--------------------------------------------------------------------------------------------------
// Trigger: Minimap Frustum - Initialization
//--------------------------------------------------------------------------------------------------
bool libEvOb_gt_MinimapFrustumInitialization_Func (bool testConds, bool runActions) {
    // Variable Declarations
    const fixed lv_baseScale = 0.5;
    const fixed lv_baseMapSize = 108.0;
    fixed lv_mapScale;
    bool lv_isActive;

    // Automatic Variable Declarations
    // Variable Initialization

    // Actions
    if (!runActions) {
        return true;
    }

    if ((UserDataGetInt("GameHeartSettings", "Minimap Frustum", "Value", 1) == 1) && (PlayerGroupCount(PlayerGroupActive()) == 2) && (PlayerGroupCount(GameAttributePlayersForTeam(1)) == 1) && (PlayerGroupCount(GameAttributePlayersForTeam(2)) == 1)) {
        libEvOb_gv_minimapFrustum.lv_playerOne = PlayerGroupPlayer(GameAttributePlayersForTeam(1), 1);
        libEvOb_gv_minimapFrustum.lv_playerTwo = PlayerGroupPlayer(GameAttributePlayersForTeam(2), 1);
        lv_mapScale = (lv_baseMapSize / MaxF(libNtve_gf_WidthOfRegion(RegionPlayableMap()), libNtve_gf_HeightOfRegion(RegionPlayableMap())));
        lv_mapScale = (lv_mapScale * lv_baseScale);
        if ((PlayerType(libEvOb_gv_minimapFrustum.lv_playerOne) == c_playerTypeUser)) {
            lv_isActive = true;
            libNtve_gf_CreatePingFacingAngle(libEvOb_gv_obs, "PingViewArea", CameraGetTarget(libEvOb_gv_minimapFrustum.lv_playerOne), libNtve_gf_ConvertPlayerColorToColor(PlayerGetColorIndex(libEvOb_gv_minimapFrustum.lv_playerOne, false)), 0.0, 270.0);
            PingSetScale(PingLastCreated(), lv_mapScale);
            libEvOb_gv_minimapFrustum.lv_ping[0] = PingLastCreated();
            libEvOb_gf_RegisterCameraMoveEvent(libEvOb_gt_MinimapFrustumPlayerCameraMoved, libEvOb_gv_minimapFrustum.lv_playerOne, c_cameraMoveReasonAny);
        }

        if ((PlayerType(libEvOb_gv_minimapFrustum.lv_playerTwo) == c_playerTypeUser)) {
            lv_isActive = true;
            libNtve_gf_CreatePingFacingAngle(libEvOb_gv_obs, "PingViewArea", CameraGetTarget(libEvOb_gv_minimapFrustum.lv_playerTwo), libNtve_gf_ConvertPlayerColorToColor(PlayerGetColorIndex(libEvOb_gv_minimapFrustum.lv_playerTwo, false)), 0.0, 270.0);
            PingSetScale(PingLastCreated(), lv_mapScale);
            libEvOb_gv_minimapFrustum.lv_ping[1] = PingLastCreated();
            libEvOb_gf_RegisterCameraMoveEvent(libEvOb_gt_MinimapFrustumPlayerCameraMoved, libEvOb_gv_minimapFrustum.lv_playerTwo, c_cameraMoveReasonAny);
        }

        if ((lv_isActive == false)) {
            return false;
        }
        else {
            libEvOb_gv_minimapFrustum.lv_active = lv_isActive;
            libEvOb_gf_RegisterPlayerLeavesEvent(libEvOb_gt_MinimapFrustumPlayerLeaves, c_playerAny, c_gameResultUndecided);
        }
    }
    else {
        return false;
    }
    return true;
}

