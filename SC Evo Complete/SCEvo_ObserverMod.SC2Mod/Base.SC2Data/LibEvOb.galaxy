//--------------------------------------------------------------------------------------------------
// Trigger: Workers Killed Notifications - Worker Killed
//--------------------------------------------------------------------------------------------------
bool libEvOb_gt_WorkersKilledNotificationsWorkerKilled_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_deadUnitOwner;
    unit lv_deadUnit;
    string lv_unitType;
    unit lv_killingUnit;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_killingUnit = libNtve_gf_KillingUnit();

    // Actions
    if (!runActions) {
        return true;
    }

    if (((EventUnitDamageDeathCheck(c_deathTypeRemove) == false) || (UnitGetType(lv_killingUnit) == "CommandCenterFlying"))) {
        lv_deadUnit = EventUnit();
        if ((UnitTestState(lv_deadUnit, c_unitStateHallucination) == false)) {
            lv_unitType = UnitGetType(lv_deadUnit);
            lv_deadUnitOwner = UnitGetOwner(lv_deadUnit);
            if (((lv_unitType == "Probe") || (lv_unitType == "Drone") || (lv_unitType == "DroneBurrowed") || (lv_unitType == "SCV") || (lv_unitType == "SCVSCBW") || (lv_unitType == "ProbeSCBW") || (lv_unitType == "DroneSCBW") || (lv_unitType == "DroneSCBW@Burrowed")) && (libEvOb_gv_workersKilledNotifications.lv_itemPanel[lv_deadUnitOwner] != c_invalidDialogControlId)) {
                if ((libEvOb_gv_workersKilledNotifications.lv_slotStatus[lv_deadUnitOwner] == libEvOb_ge_WorkersKilledNotificationsSlotStatus_Visible)) {
                    libEvOb_gv_workersKilledNotifications.lv_intKilledAmount[lv_deadUnitOwner] = (libEvOb_gv_workersKilledNotifications.lv_intKilledAmount[lv_deadUnitOwner] + 1);
                }
                else {
                    libEvOb_gv_workersKilledNotifications.lv_intKilledAmount[lv_deadUnitOwner] = 1;
                }
                libNtve_gf_SetDialogItemText(libEvOb_gv_workersKilledNotifications.lv_itemCountLabel[lv_deadUnitOwner], IntToText(libEvOb_gv_workersKilledNotifications.lv_intKilledAmount[lv_deadUnitOwner]), libEvOb_gv_obs);
                libNtve_gf_SetDialogItemImage(libEvOb_gv_workersKilledNotifications.lv_itemIcon[lv_deadUnitOwner], libEvOb_gf_IconofUnit(lv_unitType, lv_deadUnitOwner), libEvOb_gv_obs);
                if ((UnitIsValid(lv_killingUnit) == true)) {
                    libNtve_gf_SetDialogItemText(libEvOb_gv_workersKilledNotifications.lv_itemKillerPlayerIdLabel[lv_deadUnitOwner], IntToText(UnitGetOwner(lv_killingUnit)), libEvOb_gv_obs);
                }
                else {
                    libNtve_gf_SetDialogItemText(libEvOb_gv_workersKilledNotifications.lv_itemKillerPlayerIdLabel[lv_deadUnitOwner], StringToText(""), libEvOb_gv_obs);
                }
                libNtve_gf_SetDialogItemText(libEvOb_gv_workersKilledNotifications.lv_itemWorkerPlayerIdLabel[lv_deadUnitOwner], IntToText(lv_deadUnitOwner), libEvOb_gv_obs);
                libEvOb_gv_workersKilledNotifications.lv_slotStatus[lv_deadUnitOwner] = libEvOb_ge_WorkersKilledNotificationsSlotStatus_Visible;
                if (((libEvOb_gv_workersKilledNotifications.lv_intKilledAmount[lv_deadUnitOwner] > 1) || (libEvOb_gf_WorkersKilledNotificationsIsinDistanceofMainBuilding(UnitGetPosition(lv_deadUnit), lv_deadUnitOwner, 50.0) == true))) {
                    DialogControlSetVisible(libEvOb_gv_workersKilledNotifications.lv_itemPanel[lv_deadUnitOwner], libEvOb_gv_obs, true);
                    DialogControlSendAnimationEvent(libEvOb_gv_workersKilledNotifications.lv_itemCountLabel[lv_deadUnitOwner], libEvOb_gv_obs, "textUpdated");
                }

                TimerStart(libEvOb_gv_workersKilledNotifications.lv_timerDestruction[lv_deadUnitOwner], libEvOb_gv_workersKilledNotificationsVisibleGameTime, false, c_timeGame);
                return true;
            }

        }

    }

    return false;
    return true;
}

