//--------------------------------------------------------------------------------------------------
// Trigger: Upgrade Notifications - Research Cancelled
//--------------------------------------------------------------------------------------------------
bool libEvOb_gt_UpgradeNotificationsResearchCancelled_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unit lv_facility;
    int lv_slot;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_facility = EventUnit();
    lv_slot = libEvOb_gf_UpgradeNotificationsSearchFacilitySlot(lv_facility);

    // Actions
    if (!runActions) {
        return true;
    }

    if ((lv_slot >= 0)) {
        if ((lv_slot <= libEvOb_gv_upgradeNotificationsMaxUISlots)) {
            libEvOb_gv_upgradeNotifications.lv_slotStatus[lv_slot] = libEvOb_ge_UpgradeNotificationsSlotStatus_OccupiedwithdestroyedcompletedUpgrade;
            TimerStart(libEvOb_gv_upgradeNotifications.lv_timerDestruction[lv_slot], 5.0, false, c_timeGame);
            if ((UnitIsAlive(lv_facility) == false)) {
                libEvOb_gf_UpgradeNotificationsSetStatusLabel(lv_slot, StringExternal("UI/UpgradeNotification/Denied"));
            }
            else {
                libEvOb_gf_UpgradeNotificationsSetStatusLabel(lv_slot, StringExternal("UI/UpgradeNotification/Canceled"));
            }
        }
        else {
            libEvOb_gf_UpgradeNotificationsRemoveRunningUpgrade(lv_slot);
        }
        return true;
    }

    return false;
    return true;
}

