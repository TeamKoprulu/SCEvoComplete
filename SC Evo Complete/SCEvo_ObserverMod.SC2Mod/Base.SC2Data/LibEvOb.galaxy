//--------------------------------------------------------------------------------------------------
// Trigger: Upgrade Notifications - Destruction Timer Runs Out
//--------------------------------------------------------------------------------------------------
bool libEvOb_gt_UpgradeNotificationsDestructionTimerRunsOut_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_slot;
    timer lv_timer;

    // Automatic Variable Declarations
    int autoB0493DF3_ae;
    const int autoB0493DF3_ai = 1;

    // Variable Initialization

    // Actions
    if (!runActions) {
        return true;
    }

    lv_timer = EventTimer();
    autoB0493DF3_ae = MinI(libEvOb_gv_upgradeNotifications.lv_slotLastUsed, libEvOb_gv_upgradeNotificationsMaxUISlots);
    lv_slot = 0;
    for ( ; ( (autoB0493DF3_ai >= 0 && lv_slot <= autoB0493DF3_ae) || (autoB0493DF3_ai < 0 && lv_slot >= autoB0493DF3_ae) ) ; lv_slot += autoB0493DF3_ai ) {
        if ((lv_timer == libEvOb_gv_upgradeNotifications.lv_timerDestruction[lv_slot])) {
            libEvOb_gf_UpgradeNotificationsRemoveRunningUpgrade(lv_slot);
            if ((libEvOb_gv_upgradeNotifications.lv_slotLastClearedInputForUpdateThread >= 0)) {
                libEvOb_gv_upgradeNotifications.lv_slotLastClearedInputForUpdateThread = MinI(libEvOb_gv_upgradeNotifications.lv_slotLastClearedInputForUpdateThread, lv_slot);
            }
            else {
                libEvOb_gv_upgradeNotifications.lv_slotLastClearedInputForUpdateThread = lv_slot;
            }
            return true;
        }

    }
    return false;
    return true;
}

