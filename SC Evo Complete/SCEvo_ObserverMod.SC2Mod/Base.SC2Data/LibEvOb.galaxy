        return true;
    }

    if ((libEvOb_gf_LabelsUnitUsesCustomStatusBarforProduction(UnitGetType(lv_unit)) == true)) {
        lv_unitTagString = IntToString(UnitGetTag(lv_unit));
        lv_dialogItem = libNtve_gf_ValueFromDataTableDialogItem(true, (libEvOb_gv_labelsDisruptIconBG1 + lv_unitTagString));
