            }
            else {
                lv_teamsVersusModeScoreValue[1] = 2;
            }
            lv_team = 1;
            for ( ; ( (auto564D10B3_ai >= 0 && lv_team <= auto564D10B3_ae) || (auto564D10B3_ai < 0 && lv_team >= auto564D10B3_ae) ) ; lv_team += auto564D10B3_ai ) {
