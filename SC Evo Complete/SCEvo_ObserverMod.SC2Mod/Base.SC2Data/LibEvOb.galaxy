bool libEvOb_gt_ProductionTabConstructionUnitWarpMergeStarted_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unit lv_constructedUnit;
    int lv_productionType;
    string lv_constructedUnitType;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_constructedUnit = EventUnitProgressUnit();
    lv_productionType = libEvOb_ge_ProductionTabCategory_Unit;
    lv_constructedUnitType = libNtve_gf_TriggeringProgressUnitType();

    // Actions
    if (!runActions) {
        return true;
    }

    if ((UnitTypeTestAttribute(lv_constructedUnitType, c_unitAttributeStructure) == true)) {
        lv_productionType = libEvOb_ge_ProductionTabCategory_Structure;
    }

    libEvOb_gf_ProductionTabRegisterProduction(UnitGetOwner(lv_constructedUnit), (lv_constructedUnitType), lv_productionType, lv_constructedUnit, true, false, UnitGetType(EventUnit()), null);
    return true;
}

