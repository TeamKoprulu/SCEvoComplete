            DialogControlHookupUnitStatus(c_triggerControlTypeImage, "DisruptIcon1\\IconBG", lv_unit);
            lv_dialogItem = DialogControlLastCreated();
            DialogControlSetVisible(lv_dialogItem, libEvOb_gv_all_Players, false);
            libNtve_gf_SaveDataTableValueDialogItem(true, (libEvOb_gv_labelsDisruptIconBG1 + lv_unitTagString), lv_dialogItem);
