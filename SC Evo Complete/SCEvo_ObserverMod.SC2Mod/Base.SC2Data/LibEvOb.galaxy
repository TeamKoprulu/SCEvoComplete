    libEvOb_gt_ProductionTabMorphCanceled = TriggerCreate("libEvOb_gt_ProductionTabMorphCanceled_Func");
    TriggerEnable(libEvOb_gt_ProductionTabMorphCanceled, false);
    TriggerAddEventUnitAbility(libEvOb_gt_ProductionTabMorphCanceled, null, null, c_unitAbilStageCancel, false);
