    libEvOb_gt_WorkersKilledNotificationsWorkerKilled = TriggerCreate("libEvOb_gt_WorkersKilledNotificationsWorkerKilled_Func");
}

//--------------------------------------------------------------------------------------------------
// Trigger: Map Notifications - Drop
//--------------------------------------------------------------------------------------------------
bool libEvOb_gt_MapNotificationsDrop_Func (bool testConds, bool runActions) {
    // Variable Declarations
    point lv_position;
    unit lv_unit;
    int lv_ping;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_unit = EventUnit();
    lv_ping = c_invalidPingId;

    // Actions
    if (!runActions) {
        return true;
    }

    if ((UnitCargoValue(lv_unit, c_unitCargoSpaceUsed) == UnitCargoValue(lv_unit, c_unitCargoSpaceTotal)) && (UnitTypeTestAttribute(UnitGetType(lv_unit), c_unitAttributeStructure) == false) && (libEvOb_gf_MapNotificationsCargoUnitshaveFullHealth(lv_unit) == true)) {
        lv_position = UnitGetPosition(lv_unit);
        if (((libEvOb_gv_mapNotifications.lv_mostRecentPingLocation == null) || (TimerGetElapsed(libEvOb_gv_mapNotifications.lv_mostRecentTimer) >= libEvOb_gv_mapNotifications.lv_pingDuration) || (DistanceBetweenPoints(libEvOb_gv_mapNotifications.lv_mostRecentPingLocation, lv_position) > libEvOb_gv_mapNotifications.lv_minimumPickupSpacing))) {
            libNtve_gf_CreatePingFacingAngle(libEvOb_gv_obs, "PingBonus", lv_position, Color(100.00, 100.00, 0.00), libEvOb_gv_mapNotifications.lv_pingDuration, -90.0);
            lv_ping = PingLastCreated();
            PingSetObserver(lv_ping, true);
            PingSetUnit(lv_ping, lv_unit);
            libEvOb_gv_mapNotifications.lv_mostRecentPingLocation = lv_position;
            TimerStart(libEvOb_gv_mapNotifications.lv_mostRecentTimer, libEvOb_gv_mapNotifications.lv_pingDuration, false, c_timeGame);
            return true;
        }

    }

    return false;
    return true;
}

