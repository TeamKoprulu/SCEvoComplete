//--------------------------------------------------------------------------------------------------
// Trigger: Battle Report - Unit Is Damaged
//--------------------------------------------------------------------------------------------------
bool libEvOb_gt_BattleReportUnitIsDamaged_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_victimPlayer;
    int lv_opposingSideIndex;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_victimPlayer = EventPlayer();

    // Actions
    if (!runActions) {
        return true;
    }

    if ((lv_victimPlayer != EventUnitDamageSourcePlayer()) && (EventUnitDamageAttempted() > 0.0)) {
        lv_opposingSideIndex = libEvOb_gf_BattleReportGetOpposingPlayerSideIndex(lv_victimPlayer);
        if ((lv_opposingSideIndex != -1)) {
            if ((!(libEvOb_gv_battleReport.lv_battleActive))) {
                libEvOb_gf_BattleReportStartBattle();
            }
            else {
                libEvOb_gv_battleReport.lv_resetBattleEndingTimer = true;
            }
            libEvOb_gv_battleReport.lv_updateDueToDamage = true;
            libEvOb_gv_battleReportSide[lv_opposingSideIndex].lv_damageDealt += EventUnitDamageAmount();
        }
        else {
            return false;
        }
    }
    else {
        return false;
    }
    return true;
}

//--------------------------------------------------------------------------------------------------
void libEvOb_gt_BattleReportUnitIsDamaged_Init () {
    libEvOb_gt_BattleReportUnitIsDamaged = TriggerCreate("libEvOb_gt_BattleReportUnitIsDamaged_Func");
}

//--------------------------------------------------------------------------------------------------
// Trigger: Battle Report - Unit Dies
//--------------------------------------------------------------------------------------------------
bool libEvOb_gt_BattleReportUnitDies_Func (bool testConds, bool runActions) {
    // Variable Declarations
    string lv_unitType;
    string lv_unitTypeForCounter;
    string lv_unitTypeLeaderAlias;
    unit lv_unit;
    int lv_opposingSideIndex;
    int lv_mineralsCost;
    int lv_vespeneCost;
    int lv_owner;
    bool lv_deathIsCancel;
    string lv_droneType;
    string lv_unitTypeRace;

    // Automatic Variable Declarations
    // Variable Initialization

    // Actions
    if (!runActions) {
        return true;
    }

    if (libEvOb_gv_battleReport.lv_battleActive) {
        lv_unit = EventUnit();
        if ((UnitHasBehavior2(lv_unit, "NeuralParasite") == true)) {
            lv_owner = UnitGetOwner(lv_unit);
            lv_opposingSideIndex = libEvOb_gf_BattleReportGetPlayerSideIndex(lv_owner);
            lv_owner = libEvOb_gv_battleReport.lv_playerIdSide[libEvOb_gf_BattleReportGetOpposingPlayerSideIndex(lv_owner)];
        }
        else {
            lv_owner = UnitGetOwner(lv_unit);
            lv_opposingSideIndex = libEvOb_gf_BattleReportGetOpposingPlayerSideIndex(lv_owner);
        }
        if ((lv_opposingSideIndex != -1)) {
            lv_unitType = UnitGetType(lv_unit);
            if ((UnitHasBehavior2(lv_unit, "Hallucination") == false) && (UnitHasBehavior2(lv_unit, "HighTemplarSCBWHallucination") == false) && (EventUnitDamageDeathCheck(c_deathTypeRemove) == false)) {
                lv_deathIsCancel = EventUnitDamageDeathCheck(c_deathTypeCancel);
                if ((lv_deathIsCancel == false) && libEvOb_gf_BattleReportIsTrackedUnitType(lv_unit, lv_unitType, EventUnitDamageDeathCheck(c_deathTypeTimeout))) {
                    lv_unitTypeLeaderAlias = (CatalogFieldValueGet(c_gameCatalogUnit, lv_unitType, "LeaderAlias", lv_owner));
                    if ((lv_unitTypeLeaderAlias != null) && (lv_unitTypeLeaderAlias != lv_unitType)) {
                        lv_unitType = lv_unitTypeLeaderAlias;
                    }

                    lv_unitTypeForCounter = lv_unitType;
                    if ((lv_unitType == "BanelingCocoon")) {
                        lv_unitTypeForCounter = "Zergling";
                    }
                    else if ((lv_unitType == "RavagerCocoon")) {
                        lv_unitTypeForCounter = "Roach";
                    }
                    else if ((lv_unitType == "BroodLordCocoon")) {
                        lv_unitTypeForCounter = "Corruptor";
                    }
                    else if ((lv_unitType == "LurkerMPEgg")) {
                        lv_unitTypeForCounter = "Hydralisk";
                    }
                    else if ((lv_unitType == "TransportOverlordCocoon")) {
                        lv_unitTypeForCounter = "Overlord";
                    }
                    else if ((lv_unitType == "OverlordCocoon")) {
                        if ((UnitHasBehavior2(lv_unit, "AHLI_fixUnitLostResourcesOfOverlordTransport") == true)) {
                            lv_unitTypeForCounter = "OverlordTransport";
                        }
                        else {
                            lv_unitTypeForCounter = "Overlord";
                        }
                    }
                    else if (((lv_unitType == "DevourerSCBWEgg") || (lv_unitType == "GuardianSCBWEgg"))) {
                        lv_unitTypeForCounter = "MutaliskSCBW";
                    }
                    else if ((lv_unitType == "LurkerSCBWEgg")) {
                        lv_unitTypeForCounter = "HydraliskSCBW";
                    }
                    libEvOb_gf_BattleReportIncrementUnitTypeKill(lv_opposingSideIndex, lv_unitTypeForCounter);
                }

                if ((lv_unitType != "AutoTurret") && (lv_unitType != "MULE") && ((lv_deathIsCancel == false) || (UnitTypeTestAttribute(lv_unitType, c_unitAttributeStructure) == true))) {
                    lv_mineralsCost = libEvOb_gf_GetFixedUnitResourceCost(lv_unit, c_unitCostMinerals, lv_owner);
                    lv_vespeneCost = libEvOb_gf_GetFixedUnitResourceCost(lv_unit, c_unitCostVespene, lv_owner);
                    if (((lv_deathIsCancel == true) || (EventUnitDamageDeathCheck(c_deathTypeSalvage) == true))) {
                        if ((UnitTypeTestAttribute(lv_unitType, c_unitAttributeStructure) == true) && (UnitTypeTestAttribute(lv_unitType, c_unitAttributeBiological) == true) && (lv_unitType != "NydusCanal")) {
                            lv_unitTypeRace = (CatalogFieldValueGet(c_gameCatalogUnit, lv_unitType, "Race", c_playerAny));
                            if ((lv_unitTypeRace == "Zerg")) {
                                lv_droneType = "Drone";
                            }
                            else if ((lv_unitTypeRace == "BWZe")) {
                                lv_droneType = "DroneSCBW";
                            }
                            lv_mineralsCost = MaxI((lv_mineralsCost - CatalogFieldValueGetAsInt(c_gameCatalogUnit, lv_droneType, "CostResource[" + IntToString(0) + "]", lv_owner)), 0);
                            lv_vespeneCost = MaxI((lv_vespeneCost - CatalogFieldValueGetAsInt(c_gameCatalogUnit, lv_droneType, "CostResource[" + IntToString(1) + "]", lv_owner)), 0);
                        }

                        lv_mineralsCost /= 4;
                        lv_vespeneCost /= 4;
                    }

                    if (((lv_mineralsCost > 0) || (lv_vespeneCost > 0))) {
                        libEvOb_gf_BattleReportIncrementResourceDamage(lv_opposingSideIndex, lv_mineralsCost, lv_vespeneCost);
                    }

                }

                return true;
            }

        }

    }

    return false;
    return true;
}

//--------------------------------------------------------------------------------------------------
void libEvOb_gt_BattleReportUnitDies_Init () {
    libEvOb_gt_BattleReportUnitDies = TriggerCreate("libEvOb_gt_BattleReportUnitDies_Func");
}

//--------------------------------------------------------------------------------------------------
// Trigger: Battle Report - Tracked Ability Used A (battle starting)
//--------------------------------------------------------------------------------------------------
bool libEvOb_gt_BattleReportTrackedAbilityUsedAbattlestarting_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_sideIndex;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_sideIndex = libEvOb_gf_BattleReportGetPlayerSideIndex(EventPlayer());

    // Actions
    if (!runActions) {
        return true;
    }

    if ((lv_sideIndex != -1)) {
        if (libEvOb_gv_battleReport.lv_battleActive) {
            libEvOb_gv_battleReport.lv_resetBattleEndingTimer = true;
        }
        else {
            libEvOb_gf_BattleReportStartBattle();
        }
        libEvOb_gf_BattleReportIncrementAbilityUsage(lv_sideIndex, EventUnitAbility());
    }
    else {
        return false;
    }
    return true;
}

//--------------------------------------------------------------------------------------------------
void libEvOb_gt_BattleReportTrackedAbilityUsedAbattlestarting_Init () {
    libEvOb_gt_BattleReportTrackedAbilityUsedAbattlestarting = TriggerCreate("libEvOb_gt_BattleReportTrackedAbilityUsedAbattlestarting_Func");
}

//--------------------------------------------------------------------------------------------------
// Trigger: Battle Report - Tracked Ability Used B (no battle start)
//--------------------------------------------------------------------------------------------------
bool libEvOb_gt_BattleReportTrackedAbilityUsedBnobattlestart_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_sideIndex;

    // Automatic Variable Declarations
    // Variable Initialization

    // Actions
    if (!runActions) {
        return true;
    }

    if (libEvOb_gv_battleReport.lv_battleActive) {
        lv_sideIndex = libEvOb_gf_BattleReportGetPlayerSideIndex(EventPlayer());
        if ((lv_sideIndex != -1)) {
            libEvOb_gf_BattleReportIncrementAbilityUsage(lv_sideIndex, EventUnitAbility());
        }

    }
    else {
        return false;
    }
    return true;
}

//--------------------------------------------------------------------------------------------------
void libEvOb_gt_BattleReportTrackedAbilityUsedBnobattlestart_Init () {
    libEvOb_gt_BattleReportTrackedAbilityUsedBnobattlestart = TriggerCreate("libEvOb_gt_BattleReportTrackedAbilityUsedBnobattlestart_Func");
}

//--------------------------------------------------------------------------------------------------
// Trigger: Battle Report - BattleEndingTimer Expires
//--------------------------------------------------------------------------------------------------
bool libEvOb_gt_BattleReportBattleEndingTimerExpires_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Actions
    if (!runActions) {
        return true;
    }

    libEvOb_gf_BattleReportEndBattle();
    return true;
}

//--------------------------------------------------------------------------------------------------
void libEvOb_gt_BattleReportBattleEndingTimerExpires_Init () {
    libEvOb_gt_BattleReportBattleEndingTimerExpires = TriggerCreate("libEvOb_gt_BattleReportBattleEndingTimerExpires_Func");
}

//--------------------------------------------------------------------------------------------------
// Trigger: Battle Report - NoUiUpdateTimer Expires
//--------------------------------------------------------------------------------------------------
bool libEvOb_gt_BattleReportNoUiUpdateTimerExpires_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Actions
    if (!runActions) {
        return true;
    }

    libEvOb_gv_battleReport.lv_noUiUpdates = false;
    if ((libEvOb_gv_battleReport.lv_battleActive == true)) {
        DialogControlSetEnabled(libEvOb_gv_battleReport.lv_uiBattleActiveIndicator, libEvOb_gv_obs, true);
    }

    return true;
}

//--------------------------------------------------------------------------------------------------
void libEvOb_gt_BattleReportNoUiUpdateTimerExpires_Init () {
    libEvOb_gt_BattleReportNoUiUpdateTimerExpires = TriggerCreate("libEvOb_gt_BattleReportNoUiUpdateTimerExpires_Func");
}

