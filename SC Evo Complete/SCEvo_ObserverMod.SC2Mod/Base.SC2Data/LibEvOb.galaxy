    libEvOb_gt_ArchonDuplicatedTemplarsDied = TriggerCreate("libEvOb_gt_ArchonDuplicatedTemplarsDied_Func");
    TriggerAddEventPlayerEffectUsed(libEvOb_gt_ArchonDuplicatedTemplarsDied, c_playerAny, "AHLI_ArchonHTHTDies");
    TriggerAddEventPlayerEffectUsed(libEvOb_gt_ArchonDuplicatedTemplarsDied, c_playerAny, "AHLI_ArchonDTDTDies");
}

