//--------------------------------------------------------------------------------------------------
// Trigger: Upgrade Notifications - Research Started
//--------------------------------------------------------------------------------------------------
bool libEvOb_gt_UpgradeNotificationsResearchStarted_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unit lv_facility;
    string lv_upgrade;
    int lv_slot;
    int lv_player;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_slot = libEvOb_gv_upgradeNotifications.lv_slotLastUsed;

    // Actions
    if (!runActions) {
        return true;
    }

    if ((lv_slot < libEvOb_gv_upgradeNotificationsMaxFacilitySlots)) {
        lv_facility = EventUnit();
        if ((UnitIsAlive(lv_facility) == true)) {
            lv_slot += 1;
            libEvOb_gv_upgradeNotifications.lv_slotLastUsed = lv_slot;
            libEvOb_gv_upgradeNotifications.lv_slotFacility[lv_slot] = lv_facility;
            if ((lv_slot <= libEvOb_gv_upgradeNotificationsMaxUISlots)) {
                lv_upgrade = libNtve_gf_TriggeringProgressUpgrade();
                lv_player = EventPlayer();
                libEvOb_gf_UpgradeNotificationsSetSlotData(lv_slot, libEvOb_gf_UpgradeNotificationsUpgradeName(lv_upgrade), libEvOb_gf_IconofUpgrade(lv_upgrade, lv_player), lv_player, false, lv_facility);
                if ((libEvOb_gv_upgradeNotifications.lv_updateThreadRunning == false)) {
                    libEvOb_gv_upgradeNotifications.lv_updateThreadRunning = true;
                    libEvOb_gf_UpgradeNotificationsUpdateUIthreaded();
                }

                libNtve_gf_SetDialogItemText(libEvOb_gv_upgradeNotifications.lv_itemTimerStatus[lv_slot], StringToText(""), libEvOb_gv_obs);
                DialogControlSetVisible(libEvOb_gv_upgradeNotifications.lv_itemTimerLabel[lv_slot], libEvOb_gv_obs, true);
                DialogControlSetVisible(libEvOb_gv_upgradeNotifications.lv_itemTimerStatus[lv_slot], libEvOb_gv_obs, false);
                libEvOb_gv_upgradeNotifications.lv_slotStatus[lv_slot] = libEvOb_ge_UpgradeNotificationsSlotStatus_HiddenOccupiedwithrunningUpgrade;
                libNtve_gf_SetDialogItemCurrentValue(libEvOb_gv_upgradeNotifications.lv_itemProgressBar[lv_slot], 0.0, libEvOb_gv_obs);
                return true;
            }

        }

    }

    return false;
    return true;
}

