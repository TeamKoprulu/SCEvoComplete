//--------------------------------------------------------------------------------------------------
// Trigger: ProductionTab - Training Completed
//--------------------------------------------------------------------------------------------------
bool libEvOb_gt_ProductionTabTrainingCompleted_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unit lv_producer;
    string lv_unitType;
    int lv_owner;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_producer = EventUnit();
    lv_unitType = libNtve_gf_TriggeringProgressUnitType();
    lv_owner = UnitGetOwner(lv_producer);

    // Actions
    if (!runActions) {
        return true;
    }

    libEvOb_gf_ProductionTabRemoveProduction(lv_owner, (lv_unitType), libEvOb_ge_ProductionTabCategory_Unit, lv_producer);
    if (((lv_unitType == "Carrier") || (lv_unitType == "CarrierSCBW") || (lv_unitType == "ReaverSCBW"))) {
        lv_producer = EventUnitProgressUnit();
        UnitGroupAdd(libEvOb_gv_productionTabPlayer[lv_owner].lv_ignoreArmingCompletedEvents, lv_producer);
        Wait(0.125, c_timeGame);
        UnitGroupRemove(libEvOb_gv_productionTabPlayer[lv_owner].lv_ignoreArmingCompletedEvents, lv_producer);
    }

    return true;
}

