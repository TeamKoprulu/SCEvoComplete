//--------------------------------------------------------------------------------------------------
// Trigger: Graphs - Initialization
//--------------------------------------------------------------------------------------------------
bool libEvOb_gt_GraphsInitialization_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_playerT1;
    int lv_playerT2;
    fixed lv_xOfStartLocationT1;
    fixed lv_xOfStartLocationT2;

    // Automatic Variable Declarations
    // Variable Initialization

    // Actions
    if (!runActions) {
        return true;
    }

    if ((PlayerGroupCount(libEvOb_gv_initial_Active_Players) == 2) && (PlayerGroupCount(GameAttributePlayersForTeam(1)) == 1) && (PlayerGroupCount(GameAttributePlayersForTeam(2)) == 1)) {
        libEvOb_gv_graphsGeneral.lv_active = true;
        libEvOb_gf_RegisterPeriodicEvent(libEvOb_gt_GraphsTimer, libEvOb_gv_gameSpeedFactor, c_timeGame);
        lv_playerT1 = PlayerGroupPlayer(GameAttributePlayersForTeam(1), 1);
        lv_playerT2 = PlayerGroupPlayer(GameAttributePlayersForTeam(2), 1);
        lv_xOfStartLocationT1 = PointGetX(PlayerStartLocation(lv_playerT1));
        lv_xOfStartLocationT2 = PointGetX(PlayerStartLocation(lv_playerT2));
        if ((lv_xOfStartLocationT1 < lv_xOfStartLocationT2)) {
            libEvOb_gv_graphsGeneral.lv_playerLeft = lv_playerT1;
            libEvOb_gv_graphsGeneral.lv_teamLeft = 1;
            libEvOb_gv_graphsGeneral.lv_playerRight = lv_playerT2;
            libEvOb_gv_graphsGeneral.lv_teamRight = 2;
        }
        else if ((lv_xOfStartLocationT1 > lv_xOfStartLocationT2)) {
            libEvOb_gv_graphsGeneral.lv_playerLeft = lv_playerT2;
            libEvOb_gv_graphsGeneral.lv_teamLeft = 2;
            libEvOb_gv_graphsGeneral.lv_playerRight = lv_playerT1;
            libEvOb_gv_graphsGeneral.lv_teamRight = 1;
        }
        else if ((lv_playerT1 < lv_playerT2)) {
            libEvOb_gv_graphsGeneral.lv_playerLeft = lv_playerT1;
            libEvOb_gv_graphsGeneral.lv_teamLeft = 1;
            libEvOb_gv_graphsGeneral.lv_playerRight = lv_playerT2;
            libEvOb_gv_graphsGeneral.lv_teamRight = 2;
        }
        else if ((lv_playerT1 > lv_playerT2)) {
            libEvOb_gv_graphsGeneral.lv_playerLeft = lv_playerT2;
            libEvOb_gv_graphsGeneral.lv_teamLeft = 2;
            libEvOb_gv_graphsGeneral.lv_playerRight = lv_playerT1;
            libEvOb_gv_graphsGeneral.lv_teamRight = 1;
        }
        DialogControlHookupStandard(c_triggerControlTypePanel, "UIContainer/FullscreenUpperContainer/GraphContainer");
        libEvOb_gv_graphsGeneral.lv_container = DialogControlLastCreated();
        libEvOb_gf_GraphsDefineGraph(0, StringExternal("UI/Graph/IncomeAdvantage"), "IncomeGraph", "ResourceCollectionRate", libEvOb_ge_GraphStyle_Differential, 350.0, 400.0, 200.0, true);
        libEvOb_gf_GraphsDefineGraph(1, StringExternal("UI/Graph/ArmySize"), "ArmySizeGraph", "FoodUsedArmy", libEvOb_ge_GraphStyle_Comparative, 40.0, 50.0, 50.0, false);
        libEvOb_gf_GraphsDefineGraph(2, StringExternal("UI/Graph/ResourcesLost"), "ResourcesLostDiffGraph", "ResourcesLostUnits", libEvOb_ge_GraphStyle_Differential, 400.0, 500.0, 500.0, false);
        libEvOb_gf_GraphsDefineGraph(3, StringExternal("UI/Graph/ResourcesGathered"), "ResourcesGatheredGraph", "ResourcesGathered", libEvOb_ge_GraphStyle_Comparative, 7500.0, 10000.0, 10000.0, false);
    }
    else {
        return false;
    }
    return true;
}

//--------------------------------------------------------------------------------------------------
void libEvOb_gt_GraphsInitialization_Init () {
    libEvOb_gt_GraphsInitialization = TriggerCreate("libEvOb_gt_GraphsInitialization_Func");
}

//--------------------------------------------------------------------------------------------------
// Trigger: Graphs - Timer
//--------------------------------------------------------------------------------------------------
bool libEvOb_gt_GraphsTimer_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_graph;
    int lv_count;

    // Automatic Variable Declarations
    const int auto2CE2B256_ae = libEvOb_gv_graphsMaxGraphId;
    const int auto2CE2B256_ai = 1;

    // Variable Initialization

    // Actions
    if (!runActions) {
        return true;
    }

    libEvOb_gv_graphsGeneral.lv_currentInterval += 1;
    if ((libEvOb_gv_graphsGeneral.lv_currentInterval == libEvOb_gv_graphsIntervalLength)) {
        libEvOb_gv_graphsGeneral.lv_currentNode += 1;
    }

    lv_graph = 0;
    for ( ; ( (auto2CE2B256_ai >= 0 && lv_graph <= auto2CE2B256_ae) || (auto2CE2B256_ai < 0 && lv_graph >= auto2CE2B256_ae) ) ; lv_graph += auto2CE2B256_ai ) {
        libEvOb_gv_graphsData[lv_graph].lv_tempValues[libEvOb_gv_graphsGeneral.lv_teamLeft][libEvOb_gv_graphsGeneral.lv_currentInterval] = PlayerScoreValueGetAsInt(libEvOb_gv_graphsGeneral.lv_playerLeft, libEvOb_gv_graphsData[lv_graph].lv_scoreType);
        libEvOb_gv_graphsData[lv_graph].lv_tempValues[libEvOb_gv_graphsGeneral.lv_teamRight][libEvOb_gv_graphsGeneral.lv_currentInterval] = PlayerScoreValueGetAsInt(libEvOb_gv_graphsGeneral.lv_playerRight, libEvOb_gv_graphsData[lv_graph].lv_scoreType);
        if ((libEvOb_gv_graphsGeneral.lv_currentInterval == libEvOb_gv_graphsIntervalLength)) {
            if ((libEvOb_gv_graphsData[lv_graph].lv_style == libEvOb_ge_GraphStyle_Comparative)) {
                libEvOb_gf_GraphsUpdateDataComparative(lv_graph);
            }
            else {
                libEvOb_gf_GraphsUpdateDataDifferential(lv_graph);
            }
        }

    }
    if ((libEvOb_gv_graphsGeneral.lv_currentInterval == libEvOb_gv_graphsIntervalLength)) {
        libEvOb_gv_graphsGeneral.lv_currentInterval = 0;
    }

    return true;
}

//--------------------------------------------------------------------------------------------------
void libEvOb_gt_GraphsTimer_Init () {
    libEvOb_gt_GraphsTimer = TriggerCreate("libEvOb_gt_GraphsTimer_Func");
}

//--------------------------------------------------------------------------------------------------
// Trigger: Labels - Initialization
//--------------------------------------------------------------------------------------------------
bool libEvOb_gt_LabelsInitialization_Func (bool testConds, bool runActions) {
    // Variable Declarations
    bool lv_labelUnitsEnabled;
    bool lv_labelResearchEnabled;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_labelUnitsEnabled = (UserDataGetInt("GameHeartSettings", "Labels (Units)", "Value", 1) == 1);
    lv_labelResearchEnabled = (UserDataGetInt("GameHeartSettings", "Labels (Research)", "Value", 1) == 1);

    // Actions
    if (!runActions) {
        return true;
    }

    if (((lv_labelUnitsEnabled == true) || (lv_labelResearchEnabled == true))) {
        libEvOb_gv_labels.lv_active = true;
        if ((lv_labelUnitsEnabled == true)) {
            libEvOb_gf_RegisterUnitTrainingProgressEvent(libEvOb_gt_LabelsUnitTrainingStarted, null, c_unitProgressStageStart);
            libEvOb_gf_RegisterUnitArmingProgressEvent(libEvOb_gt_LabelsUnitTrainingStarted, null, c_unitProgressStageStart);
            libEvOb_gf_RegisterUnitTrainingProgressEvent(libEvOb_gt_LabelsUnitTrainingStopped, null, c_unitProgressStageComplete);
            libEvOb_gf_RegisterUnitTrainingProgressEvent(libEvOb_gt_LabelsUnitTrainingStopped, null, c_unitProgressStageCancel);
            libEvOb_gf_RegisterUnitArmingProgressEvent(libEvOb_gt_LabelsUnitTrainingStopped, null, c_unitProgressStageComplete);
            libEvOb_gf_RegisterUnitArmingProgressEvent(libEvOb_gt_LabelsUnitTrainingStopped, null, c_unitProgressStageCancel);
            libEvOb_gf_RegisterUnitDiesEvent(libEvOb_gt_LabelsReactorDestroyed, null);
        }

        if ((lv_labelResearchEnabled == true)) {
            libEvOb_gf_RegisterUnitResearchProgressEvent(libEvOb_gt_LabelsResearchStarted, null, c_unitProgressStageStart);
            libEvOb_gf_RegisterUnitResearchProgressEvent(libEvOb_gt_LabelsResearchStopped, null, c_unitProgressStageComplete);
            libEvOb_gf_RegisterUnitResearchProgressEvent(libEvOb_gt_LabelsResearchStopped, null, c_unitProgressStageCancel);
        }

    }
    else {
        return false;
    }
    return true;
}

//--------------------------------------------------------------------------------------------------
void libEvOb_gt_LabelsInitialization_Init () {
    libEvOb_gt_LabelsInitialization = TriggerCreate("libEvOb_gt_LabelsInitialization_Func");
}

//--------------------------------------------------------------------------------------------------
// Trigger: Labels - Unit Training Started
//--------------------------------------------------------------------------------------------------
bool libEvOb_gt_LabelsUnitTrainingStarted_Func (bool testConds, bool runActions) {
    // Variable Declarations
    string lv_unitTagString;
    string lv_unitTagStringSlot1;
    string lv_unitTagStringSlot2;
    bool lv_reactorTags;
    int lv_dialogItem;
    string lv_savedTypeSlot1;
    string lv_savedTypeSlot2;
    string lv_traineeType;
    unit lv_unit;
    string lv_unitType;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_dialogItem = c_invalidDialogControlId;
    lv_traineeType = libNtve_gf_TriggeringProgressUnitType();
    lv_unit = EventUnit();
    lv_unitType = UnitGetType(lv_unit);

    // Actions
    if (!runActions) {
        return true;
    }

    if (((UnitTypeTestAttribute(lv_unitType, c_unitAttributeStructure) == true) || ((lv_unitType == "Egg") || (lv_unitType == "EggSCBW")))) {
        lv_unitTagString = IntToString(UnitGetTag(lv_unit));
        libEvOb_gf_LabelsHookUpUnitsProductionTag(lv_unit, lv_unitTagString);
        lv_unitTagStringSlot1 = (lv_unitTagString + libEvOb_gv_labelsSlot1);
        lv_unitTagStringSlot2 = (lv_unitTagString + libEvOb_gv_labelsSlot2);
        lv_savedTypeSlot1 = DataTableGetString(true, lv_unitTagStringSlot1);
        if ((lv_savedTypeSlot1 == "")) {
            DataTableSetString(true, lv_unitTagStringSlot1, (lv_traineeType));
            lv_savedTypeSlot1 = (lv_traineeType);
            lv_savedTypeSlot2 = DataTableGetString(true, lv_unitTagStringSlot2);
            if ((lv_savedTypeSlot2 != "")) {
                lv_reactorTags = true;
            }

        }
        else {
            if (((lv_traineeType == "Zergling") || (lv_traineeType == "ZerglingSCBW") || (lv_traineeType == "ScourgeSCBW")) && (lv_savedTypeSlot1 == (lv_traineeType))) {
                return false;
            }

            DataTableSetString(true, lv_unitTagStringSlot2, (lv_traineeType));
            lv_savedTypeSlot2 = (lv_traineeType);
            lv_reactorTags = true;
        }
        if ((lv_reactorTags == true)) {
            DialogControlSetVisible(libNtve_gf_ValueFromDataTableDialogItem(true, (libEvOb_gv_labelsIconBG1 + lv_unitTagString)), libEvOb_gv_obs, false);
            DialogControlSetVisible(libNtve_gf_ValueFromDataTableDialogItem(true, (libEvOb_gv_labelsIcon1 + lv_unitTagString)), libEvOb_gv_obs, false);
            DialogControlSetVisible(libNtve_gf_ValueFromDataTableDialogItem(true, (libEvOb_gv_labelsIconBG2 + lv_unitTagString)), libEvOb_gv_obs, true);
            lv_dialogItem = libNtve_gf_ValueFromDataTableDialogItem(true, (libEvOb_gv_labelsIcon2 + lv_unitTagString));
            libNtve_gf_SetDialogItemImage(lv_dialogItem, (CatalogFieldValueGet(c_gameCatalogActor, (lv_savedTypeSlot1), "UnitIcon", c_playerAny)), libEvOb_gv_obs);
            DialogControlSetVisible(lv_dialogItem, libEvOb_gv_obs, true);
            DialogControlSetVisible(libNtve_gf_ValueFromDataTableDialogItem(true, (libEvOb_gv_labelsIconBG3 + lv_unitTagString)), libEvOb_gv_obs, true);
            lv_dialogItem = libNtve_gf_ValueFromDataTableDialogItem(true, (libEvOb_gv_labelsIcon3 + lv_unitTagString));
            libNtve_gf_SetDialogItemImage(lv_dialogItem, (CatalogFieldValueGet(c_gameCatalogActor, (lv_savedTypeSlot2), "UnitIcon", c_playerAny)), libEvOb_gv_obs);
            DialogControlSetVisible(lv_dialogItem, libEvOb_gv_obs, true);
        }
        else {
            DialogControlSetVisible(libNtve_gf_ValueFromDataTableDialogItem(true, (libEvOb_gv_labelsIconBG1 + lv_unitTagString)), libEvOb_gv_obs, true);
            lv_dialogItem = libNtve_gf_ValueFromDataTableDialogItem(true, (libEvOb_gv_labelsIcon1 + lv_unitTagString));
            libNtve_gf_SetDialogItemImage(lv_dialogItem, (CatalogFieldValueGet(c_gameCatalogActor, (lv_savedTypeSlot1), "UnitIcon", c_playerAny)), libEvOb_gv_obs);
            DialogControlSetVisible(lv_dialogItem, libEvOb_gv_obs, true);
        }
    }
    else {
        return false;
    }
    return true;
}

//--------------------------------------------------------------------------------------------------
void libEvOb_gt_LabelsUnitTrainingStarted_Init () {
    libEvOb_gt_LabelsUnitTrainingStarted = TriggerCreate("libEvOb_gt_LabelsUnitTrainingStarted_Func");
}

