    <Style name="InfoPaneUnitType_BWTe" template="InfoPaneUnitType" textcolor="#ColorTerranLabel"/>
    <Style name="InfoPaneUnitType_BWZe" template="InfoPaneUnitType" textcolor="#ColorZergLabel"/>
