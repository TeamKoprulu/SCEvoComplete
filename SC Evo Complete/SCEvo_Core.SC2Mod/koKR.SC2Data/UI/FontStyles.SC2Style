    <Style name="InfoPaneUnitInfo_BWPr" template="InfoPaneUnitInfo" textcolor="#ColorProtossLabel"/>
    <Style name="InfoPaneUnitInfo_BWTe" template="InfoPaneUnitInfo" textcolor="#ColorTerranLabel"/>
    <Style name="InfoPaneUnitInfo_BWZe" template="InfoPaneUnitInfo" textcolor="#ColorZergLabel"/>
    <Style name="InfoPaneQueueName" template="HeaderExtendedTemplate" height="28" hjustify="Center" textcolor="#ColorTerranLabel"/>
    <Style name="InfoPaneQueueName_BWPr" template="InfoPaneQueueName" textcolor="#ColorProtossLabel"/>
    <Style name="InfoPaneQueueName_BWTe" template="InfoPaneQueueName" textcolor="#ColorTerranLabel"/>
    <Style name="InfoPaneQueueName_BWZe" template="InfoPaneQueueName" textcolor="#ColorZergLabel"/>
