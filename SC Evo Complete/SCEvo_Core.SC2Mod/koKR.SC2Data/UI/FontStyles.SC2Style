    <Style name="ObjectivePanelCategory_BWPr" template="ObjectivePanelCategory" font="LocalizedData/Fonts/Kostar.ttf" height="16" vjustify="Middle" hjustify="Right" styleflags="Glow" textcolor="255,255,255,255" highlightcolor="255,0,0,0" disabledcolor="255,0,0,0" hotkeycolor="255,0,0,0" hyperlinkcolor="255,0,0,0" glowcolor="255,0,138,255" shadowoffset="1" outlinewidth="0"/>
