    <Style name="StandardTooltipHeaderSub_BWPr" template="StandardTooltipHeaderSub" textcolor="#ColorProtossLabel"/>
    <Style name="StandardTooltipHeaderSub_BWTe" template="StandardTooltipHeaderSub" textcolor="#ColorTerranLabel"/>
    <Style name="StandardTooltipHeaderSub_BWZe" template="StandardTooltipHeaderSub" textcolor="#ColorZergLabel"/>
