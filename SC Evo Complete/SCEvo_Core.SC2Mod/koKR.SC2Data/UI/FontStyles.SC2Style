    <Style name="InfoPaneProgressName_BWTe" template="InfoPaneProgressName" textcolor="#ColorTerranLabel"/>
    <Style name="InfoPaneProgressName_BWZe" template="InfoPaneProgressName" textcolor="#ColorZergLabel"/>
