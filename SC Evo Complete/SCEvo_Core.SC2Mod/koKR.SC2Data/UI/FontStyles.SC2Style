<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<StyleFile>

<!-- Region: Font Groups -->
    <FontGroup name="HeaderFontGroup">
        <CodepointRange font="#BlizzardGlobal"/>
        <CodepointRange font="LocalizedData/Fonts/KostarB.ttf"/>
    </FontGroup>
    <Constant name="FontHeader" val="HeaderFontGroup"/>

    <FontGroup name="ExtHeaderFontGroup">
        <CodepointRange font="#BlizzardGlobal"/>
        <CodepointRange font="LocalizedData/Fonts/KostarExtM.ttf"/>
    </FontGroup>
    <Constant name="FontHeaderExtended" val="ExtHeaderFontGroup"/>

    <FontGroup name="StandardFontGroup">
        <CodepointRange font="#BlizzardGlobal"/>
        <CodepointRange font="LocalizedData/Fonts/Kostar.ttf"/>
    </FontGroup>
    <Constant name="FontStandard" val="StandardFontGroup"/>

    <FontGroup name="ExtStandardFontGroup">
        <CodepointRange font="#BlizzardGlobal"/>
        <CodepointRange font="LocalizedData/Fonts/KostarExtR.ttf"/>
    </FontGroup>
    <Constant name="FontStandardExtended" val="ExtStandardFontGroup"/>
<!-- EndRegion: Font Groups -->

<!-- Region: Styles -->
    <!-- Template Styles -->
    <Style name="HeaderTemplate" font="#FontHeader" styleflags="Shadow" shadowoffset="#ShadowOffsetNormal"/>
    <Style name="StandardTemplate" font="#FontStandard" styleflags="Shadow" shadowoffset="#ShadowOffsetNormal"/>
    <Style name="HeaderExtendedTemplate" font="#FontHeaderExtended" styleflags="Shadow" shadowoffset="#ShadowOffsetNormal"/>
    <Style name="StandardExtendedTemplate" font="#FontStandardExtended" styleflags="Shadow" shadowoffset="#ShadowOffsetNormal"/>
    <Style name="InternationalTemplate" font="#FontInternational" styleflags="Shadow" shadowoffset="#ShadowOffsetNormal"/>
    <Style name="MonospaceTemplate" font="#FontMonospace" styleflags="Shadow" shadowoffset="#ShadowOffsetNormal"/>

    <Style requiredtoload="DEBUG" name="zz_DebugGlyphType"  font="DebugGlyphTypeFontGroup" height="80" textcolor="FFFFFFFF" styleflags="Outline" outlinewidth="2"/>

    <!-- In-Game UI Styles -->
    <Style name="InfoPaneUnitName" template="HeaderExtendedTemplate" height="24" hjustify="Center" textcolor="#ColorTerranLabel"/>
    <Style name="InfoPaneUnitName_BWTe" template="InfoPaneUnitName" textcolor="#ColorTerranLabel"/>
    <Style name="InfoPaneUnitName_BWPr" template="InfoPaneUnitName" textcolor="#ColorProtossLabel"/>
    <Style name="InfoPaneUnitName_BWZe" template="InfoPaneUnitName" textcolor="#ColorZergLabel"/>
    <Style name="InfoPaneUnitSubtitle" template="StandardTemplate" height="18" hjustify="Center" textcolor="#ColorTerranLabel"/>
    <Style name="InfoPaneUnitSubtitle_BWPr" template="InfoPaneUnitSubtitle" textcolor="#ColorProtossLabel"/>
    <Style name="InfoPaneUnitSubtitle_BWTe" template="InfoPaneUnitSubtitle" textcolor="#ColorTerranLabel"/>
    <Style name="InfoPaneUnitSubtitle_BWZe" template="InfoPaneUnitSubtitle" textcolor="#ColorZergLabel"/>
    <Style name="InfoPaneUnitRank" template="HeaderExtendedTemplate" height="#FontSizeMedium" hjustify="Center" textcolor="#ColorTerranLabel"/>
    <Style name="InfoPaneUnitRank_BWPr" template="InfoPaneUnitRank" textcolor="#ColorProtossLabel"/>
    <Style name="InfoPaneUnitRank_BWTe" template="InfoPaneUnitRank" textcolor="#ColorTerranLabel"/>
    <Style name="InfoPaneUnitRank_BWZe" template="InfoPaneUnitRank" textcolor="#ColorZergLabel"/>
