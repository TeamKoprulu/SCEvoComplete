    <Style name="InfoPaneCargoName_BWPr" template="InfoPaneCargoName" textcolor="#ColorProtossLabel"/>
    <Style name="InfoPaneCargoName_BWTe" template="InfoPaneCargoName" textcolor="#ColorTerranLabel"/>
    <Style name="InfoPaneCargoName_BWZe" template="InfoPaneCargoName" textcolor="#ColorZergLabel"/>
    <Style name="InfoPaneCargoCurrentCargo" template="StandardExtendedTemplate" height="#FontSizeSmall" hjustify="Center" textcolor="#ColorTerranLabel"/>
    <Style name="InfoPaneCargoCurrentCargo_BWPr" template="InfoPaneCargoCurrentCargo" textcolor="#ColorProtossLabel"/>
    <Style name="InfoPaneCargoCurrentCargo_BWTe" template="InfoPaneCargoCurrentCargo" textcolor="#ColorTerranLabel"/>
    <Style name="InfoPaneCargoCurrentCargo_BWZe" template="InfoPaneCargoCurrentCargo" textcolor="#ColorZergLabel"/>

    <!-- Tooltips -->
    <Style name="StandardTooltip" template="StandardTemplate" height="20" vjustify="Middle" hjustify="Left" styleflags="!Shadow" textcolor="84d2ff" hotkeycolor="ffffff" hyperlinkcolor="84d2ff" />
    <Style name="StandardTooltip_BWPr" template="StandardTooltip" textcolor="#ColorProtossTooltip"/>
    <Style name="StandardTooltip_BWTe" template="StandardTooltip" textcolor="#ColorTerranTooltip"/>
    <Style name="StandardTooltip_BWZe" template="StandardTooltip" textcolor="#ColorZergTooltip"/>
    <Style name="StandardTooltipHeader" template="HeaderExtendedTemplate" height="20" vjustify="Middle" hjustify="Left" styleflags="!Shadow" textcolor="c1ffff" hotkeycolor="ffffff"/>
    <Style name="StandardTooltipHeader_BWPr" template="StandardTooltipHeader" textcolor="#ColorProtossLabel"/>
    <Style name="StandardTooltipHeader_BWTe" template="StandardTooltipHeader" textcolor="#ColorTerranLabel"/>
    <Style name="StandardTooltipHeader_BWZe" template="StandardTooltipHeader" textcolor="#ColorZergLabel"/>
