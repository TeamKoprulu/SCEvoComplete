    <Style name="HelpGameMechanicsPanelHeader_BWTe" template="HelpGameMechanicsPanelHeader" textcolor="defee3"/>
    <Style name="HelpGameMechanicsPanelHeader_BWZe" template="HelpGameMechanicsPanelHeader" textcolor="fef4e1"/>
