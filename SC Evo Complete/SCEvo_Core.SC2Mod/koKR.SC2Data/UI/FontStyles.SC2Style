    <Style name="CommandTooltipRequirements_BWTe" template="StandardTemplate" height="20" textcolor="#ColorTerranLabel"/>
    <Style name="CommandTooltipRequirements_BWZe" template="StandardTemplate" height="20" textcolor="#ColorZergLabel"/>

    <!--Menu Bar -->
    <Style name="MenuBarButton" template="StandardExtendedTemplate" height="16" vjustify="Middle" hjustify="Center" textcolor="#ColorTerranLabel" highlightcolor="#ColorWhite"/>
    <Style name="MenuBarButton_BWPr" template="MenuBarButton" textcolor="#ColorProtossLabel"/>
    <Style name="MenuBarButton_BWTe" template="MenuBarButton" textcolor="#ColorTerranLabel"/>
    <Style name="MenuBarButton_BWZe" template="MenuBarButton" textcolor="#ColorZergLabel"/>
    <Style name="MenuBarButtonKey" template="StandardExtendedTemplate" height="14" vjustify="Middle" hjustify="Center"/>

    <!-- Help Panel -->
