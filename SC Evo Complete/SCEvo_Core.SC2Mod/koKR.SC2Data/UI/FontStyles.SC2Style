    <Style name="ObjectivePanelCategory_BWZe" template="ObjectivePanelCategory" textcolor="#ObjectiveCategory" styleflags="Glow" glowcolor="#GlowColorOrange"/>    
    <Style name="ObjectivePanelProgress_BWTe" template="ObjectivePanelActive" textcolor="52e787" shadowoffset="1"/>

