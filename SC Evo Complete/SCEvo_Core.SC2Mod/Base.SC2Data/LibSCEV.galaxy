    TriggerEnable(libSCEV_gt_RaceSupplyOwnerChange, false);
    TriggerAddEventUnitChangeOwner(libSCEV_gt_RaceSupplyOwnerChange, null);
}

//--------------------------------------------------------------------------------------------------
// Trigger: RaceSupply:SupplyBoosts
//--------------------------------------------------------------------------------------------------
bool libSCEV_gt_RaceSupplySupplyBoosts_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unit lv_unit;
    int lv_player;
    int lv_raceGroup;
    fixed lv_foodValue;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_unit = EventUnit();

    // Conditions
    if (testConds) {
        if (!((UnitIsValid(lv_unit) == true))) {
            return false;
        }

        if (!((libSCEV_gv_raceSupplyActivated[UnitGetOwner(lv_unit)] == true))) {
            return false;
        }

        if (!((UnitFilterMatch(lv_unit, UnitGetOwner(lv_unit), libSCEV_gv_raceSupplyFilter) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    lv_player = UnitGetOwner(lv_unit);
    lv_raceGroup = libSCEV_gf_RaceSupplyGetRaceGroupFromUnit(lv_unit, lv_player);
    if ((libSCEV_gf_RaceSupplyRaceGroupIsActive(lv_player, lv_raceGroup) == false)) {
        return true;
    }

    lv_foodValue = libSCEV_gf_RaceSupplyGetFoodCost(lv_unit);
    lv_foodValue += libNtve_gf_CatalogFieldValueGetAsReal(c_gameCatalogBehavior, (EventUnitBehavior()), "Modification.Food", c_playerAny);
    if ((lv_foodValue > 0.0)) {
        if ((UnitGroupHasUnit(libSCEV_gv_raceSupplyData[lv_player][lv_raceGroup].lv_providers, lv_unit) == false)) {
            libSCEV_gf_RaceSupplyRegisterProvider(true, lv_unit, lv_player, lv_raceGroup);
        }
        else {
            libSCEV_gf_RaceSupplySyncSendEvent(lv_player, lv_raceGroup);
        }
    }

    return true;
}

