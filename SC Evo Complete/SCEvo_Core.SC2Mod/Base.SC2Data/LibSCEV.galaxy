//--------------------------------------------------------------------------------------------------
// Trigger: CustomizeMenu:DebugToggle
//--------------------------------------------------------------------------------------------------
bool libSCEV_gt_CustomizeMenuDebugToggle_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Conditions
    if (testConds) {
        if (!((GameIsOnline() == false))) {
            return false;
        }

        if (!((GameIsTestMap(false) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    if (((libSCEV_gv_customizeMenuDialog == c_invalidDialogId) || (DialogIsVisible(libSCEV_gv_customizeMenuDialog, EventPlayer()) == false))) {
        libNtve_gf_HideGameUI(false, PlayerGroupAll());
        libSCEV_gf_CustomizeMenuDisplay(true, PlayerGroupAll());
        libSCEV_gv_customizeMenuGameUIHidden = true;
    }
    else {
        libSCEV_gf_CustomizeMenuDisplay(false, PlayerGroupAll());
        libNtve_gf_HideGameUI(true, PlayerGroupAll());
        libSCEV_gv_customizeMenuGameUIHidden = false;
    }
    return true;
}

//--------------------------------------------------------------------------------------------------
void libSCEV_gt_CustomizeMenuDebugToggle_Init () {
    libSCEV_gt_CustomizeMenuDebugToggle = TriggerCreate("libSCEV_gt_CustomizeMenuDebugToggle_Func");
    TriggerEnable(libSCEV_gt_CustomizeMenuDebugToggle, false);
    TriggerAddEventKeyPressed(libSCEV_gt_CustomizeMenuDebugToggle, c_playerAny, c_keyF3, true, c_keyModifierStateRequire, c_keyModifierStateIgnore, c_keyModifierStateIgnore);
}

//--------------------------------------------------------------------------------------------------
// Trigger: CustomizeMenu:Close
//--------------------------------------------------------------------------------------------------
bool libSCEV_gt_CustomizeMenuClose_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Conditions
    if (testConds) {
        if (!((GameIsOnline() == false))) {
            return false;
        }

        if (!((DialogIsVisible(libSCEV_gv_customizeMenuDialog, EventPlayer()) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    libSCEV_gf_DifficultyOptionsBankSave(EventPlayer());
    libSCEV_gf_CustomizeMenuDisplay(false, PlayerGroupAll());
    if ((libSCEV_gv_customizeMenuGameUIHidden == true)) {
        libNtve_gf_HideGameUI(true, PlayerGroupAll());
        libSCEV_gv_customizeMenuGameUIHidden = false;
    }

    return true;
}

//--------------------------------------------------------------------------------------------------
void libSCEV_gt_CustomizeMenuClose_Init () {
    libSCEV_gt_CustomizeMenuClose = TriggerCreate("libSCEV_gt_CustomizeMenuClose_Func");
    TriggerEnable(libSCEV_gt_CustomizeMenuClose, false);
}

//--------------------------------------------------------------------------------------------------
// Trigger: DifficultyOptions:Responses
//--------------------------------------------------------------------------------------------------
bool libSCEV_gt_DifficultyOptionsResponses_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_usedItem;
    playergroup lv_triggeringPlayer;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_usedItem = EventDialogControl();
    lv_triggeringPlayer = PlayerGroupSingle(EventPlayer());

    // Conditions
    if (testConds) {
        if (!((TriggerIsEnabled(TriggerGetCurrent()) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    TriggerEnable(TriggerGetCurrent(), false);
    if ((lv_usedItem == libSCEV_gv_difficultyOptionsPresetButton[0])) {
        libSCEV_gf_DifficultyOptionsPresetSelect("Hardcore", lv_triggeringPlayer);
    }
    else if ((lv_usedItem == libSCEV_gv_difficultyOptionsPresetButton[1])) {
        libSCEV_gf_DifficultyOptionsPresetSelect("Legacy", lv_triggeringPlayer);
    }
    else if ((lv_usedItem == libSCEV_gv_difficultyOptionsPresetButton[2])) {
        libSCEV_gf_DifficultyOptionsPresetSelect("Remastered", lv_triggeringPlayer);
    }
    else if ((lv_usedItem == libSCEV_gv_difficultyOptionsPresetButton[3])) {
        libSCEV_gf_DifficultyOptionsPresetSelect("Custom", lv_triggeringPlayer);
    }
    else if (true) {
        libSCEV_gf_DifficultyOptionsPresetSelect("Custom", lv_triggeringPlayer);
    }
    libSCEV_gf_DifficultyOptionsSetActivatedOptions(EventPlayer());
    if ((DialogIsVisible(libSCEV_gv_customizeMenuDialog, EventPlayer()) == true)) {
        Wait(0.125, c_timeGame);
        TriggerEnable(libSCEV_gt_DifficultyOptionsResponses, true);
    }

    return true;
}

//--------------------------------------------------------------------------------------------------
void libSCEV_gt_DifficultyOptionsResponses_Init () {
    libSCEV_gt_DifficultyOptionsResponses = TriggerCreate("libSCEV_gt_DifficultyOptionsResponses_Func");
    TriggerEnable(libSCEV_gt_DifficultyOptionsResponses, false);
}

