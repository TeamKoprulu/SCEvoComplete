    TriggerEnable(libSCEV_gt_RaceSupplyTrainEvent, lp_onOff);
    TriggerEnable(libSCEV_gt_RaceSupplyMorphStart, lp_onOff);
    TriggerEnable(libSCEV_gt_RaceSupplyMorphConstructionStart, lp_onOff);
    TriggerEnable(libSCEV_gt_RaceSupplyConstructionFinish, lp_onOff);
    TriggerEnable(libSCEV_gt_RaceSupplyMergeStart, lp_onOff);
    TriggerEnable(libSCEV_gt_RaceSupplyArmingFinished, lp_onOff);
    TriggerEnable(libSCEV_gt_RaceSupplyOwnerChange, lp_onOff);
    TriggerEnable(libSCEV_gt_RaceSupplySupplyBoosts, lp_onOff);
