}

//--------------------------------------------------------------------------------------------------
// Trigger: LegacySelection:ControlGroupRecall
//--------------------------------------------------------------------------------------------------
bool libSCEV_gt_LegacySelectionControlGroupRecall_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_player;
    int lv_groupIndex;
    unitgroup lv_controlGroupUnits;
    unit lv_unit;

    // Automatic Variable Declarations
    unitgroup auto7C725F15_g;
    int auto7C725F15_u;
    unit auto7C725F15_var;

    // Variable Initialization
    lv_player = EventPlayer();
    lv_groupIndex = libSCEV_gf_LegacySelectionGetControlGroupIndex(EventHotkeyPressed());
    lv_controlGroupUnits = UnitControlGroup(lv_player, lv_groupIndex);
    lv_unit = UnitGroupUnit(lv_controlGroupUnits, 1);

    // Conditions
    if (testConds) {
        if (!((lv_groupIndex != -1))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    if ((UnitTypeTestAttribute(UnitGetType(lv_unit), c_unitAttributeStructure) == true)) {
        if ((TimerGetRemaining(libSCEV_gv_legacySelectionControlGroupRecallTimer[lv_player]) > 0.0) && (libSCEV_gv_legacySelectionLastControlGroupRecall[lv_player] == lv_groupIndex)) {
            libSCEV_gv_legacySelectionLastControlGroupRecall[lv_player] = -1;
            libNtve_gf_StopTimer(libSCEV_gv_legacySelectionControlGroupRecallTimer[lv_player]);
            CameraPan(EventPlayer(), PointWithOffsetPolar(UnitGroupCenterOfGroup(UnitControlGroup(lv_player, lv_groupIndex)), -1.73, CameraGetYaw(lv_player)), 0.0, -1, 10.0, false);
        }
        else {
            if ((UnitHasBehavior2(lv_unit, "LegacySelection@Unselectable") == true)) {
                libSCEV_gv_legacySelectionLastControlGroupRecall[lv_player] = lv_groupIndex;
                TimerStart(libSCEV_gv_legacySelectionControlGroupRecallTimer[lv_player], 0.75, false, c_timeGame);
            }

        }
        UnitGroupSelect(UnitGroupSelected(lv_player), lv_player, false);
        auto7C725F15_g = lv_controlGroupUnits;
        auto7C725F15_u = UnitGroupCount(auto7C725F15_g, c_unitCountAll);
        for (;; auto7C725F15_u -= 1) {
            auto7C725F15_var = UnitGroupUnitFromEnd(auto7C725F15_g, auto7C725F15_u);
            if (auto7C725F15_var == null) { break; }
            UnitBehaviorRemovePlayer(auto7C725F15_var, "LegacySelection@Unselectable", lv_player, 1);
        }
        UnitGroupSelect(lv_controlGroupUnits, lv_player, true);
    }
    else {
        libSCEV_gv_legacySelectionLastControlGroupRecall[lv_player] = -1;
    }
    return true;
}

//--------------------------------------------------------------------------------------------------
void libSCEV_gt_LegacySelectionControlGroupRecall_Init () {
    libSCEV_gt_LegacySelectionControlGroupRecall = TriggerCreate("libSCEV_gt_LegacySelectionControlGroupRecall_Func");
    TriggerEnable(libSCEV_gt_LegacySelectionControlGroupRecall, false);
}

