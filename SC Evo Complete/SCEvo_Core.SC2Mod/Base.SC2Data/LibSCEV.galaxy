        if (((libSCEV_gv_legacySelectionDragging[lv_player] == false) || ((libSCEV_gv_legacySelectionDragging[lv_player] == true) && (libSCEV_gv_legacySelectionShiftDown[lv_player] == true) && (UnitGroupCount(libSCEV_gv_legacySelectionSelectedUnits[lv_player], c_unitCountAlive) > 0)))) {
            auto1668C082_g = lv_group[lv_player];
            auto1668C082_u = UnitGroupCount(auto1668C082_g, c_unitCountAll);
            for (;; auto1668C082_u -= 1) {
