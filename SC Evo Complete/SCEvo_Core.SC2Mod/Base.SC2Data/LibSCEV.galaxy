    // Variable Declarations
    int lv_player;
    int lv_raceGroup;
    fixed lv_food;
    unit lv_unit;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_unit = EventUnit();

    // Conditions
    if (testConds) {
        if (!((UnitIsValid(lv_unit) == true))) {
            return false;
        }

        if (!((libSCEV_gv_raceSupplyActivated[UnitGetOwner(lv_unit)] == true))) {
            return false;
        }

        if (!((UnitFilterMatch(lv_unit, UnitGetOwner(lv_unit), libSCEV_gv_raceSupplyFilter) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
