    }

    lv_player = UnitGetOwner(lv_unit);
    lv_raceGroup = libSCEV_gf_RaceSupplyGetRaceGroupFromUnit(lv_unit, lv_player);
    if (((libSCEV_gf_RaceSupplyRaceGroupIsActive(lv_player, lv_raceGroup) == false) || (libSCEV_gf_RaceSupplyIsMorphUnit(UnitGetType(lv_unit), lv_player, lv_raceGroup) == false))) {
