//--------------------------------------------------------------------------------------------------
// Trigger: RaceSupply:OwnerChange
//--------------------------------------------------------------------------------------------------
bool libSCEV_gt_RaceSupplyOwnerChange_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_raceGroup;
    int lv_player;
    unit lv_unit;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_unit = EventUnit();

    // Conditions
    if (testConds) {
        if (!((UnitIsValid(lv_unit) == true))) {
            return false;
        }

        if (!(((libSCEV_gv_raceSupplyActivated[EventUnitOwnerOld()] == true) || (libSCEV_gv_raceSupplyActivated[EventUnitOwnerNew()] == true)))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    Wait(0.0, c_timeGame);
    if (((UnitIsValid(lv_unit) == false) || (UnitHasBehavior2(lv_unit, "SCBW_RaceSupply@TempMindControl") == true))) {
        return true;
    }

    lv_player = EventUnitOwnerOld();
    if ((libSCEV_gv_raceSupplyActivated[lv_player] == true)) {
        lv_raceGroup = libSCEV_gf_RaceSupplyGetRaceGroupFromUnit(lv_unit, lv_player);
        if ((lv_raceGroup != -1) && (libSCEV_gv_raceSupplyData[lv_player][lv_raceGroup].lv_active == true)) {
            if ((UnitGroupHasUnit(libSCEV_gv_raceSupplyData[lv_player][lv_raceGroup].lv_consumers, lv_unit) == true)) {
                libSCEV_gf_RaceSupplyRegisterConsumer(false, lv_unit, lv_player, lv_raceGroup);
            }
            else if ((UnitGroupHasUnit(libSCEV_gv_raceSupplyData[lv_player][lv_raceGroup].lv_producers, lv_unit) == true)) {
                libSCEV_gf_RaceSupplyRegisterProducer(false, lv_unit, lv_player, lv_raceGroup);
            }
            else if ((UnitGroupHasUnit(libSCEV_gv_raceSupplyData[lv_player][lv_raceGroup].lv_providers, lv_unit) == true)) {
                libSCEV_gf_RaceSupplyRegisterProvider(false, lv_unit, lv_player, lv_raceGroup);
            }
        }

    }

    lv_player = EventUnitOwnerNew();
    if ((libSCEV_gv_raceSupplyActivated[lv_player] == true)) {
        lv_raceGroup = libSCEV_gf_RaceSupplyGetRaceGroupFromUnit(lv_unit, lv_player);
        if ((lv_raceGroup != -1) && (libSCEV_gv_raceSupplyData[lv_player][lv_raceGroup].lv_active == true)) {
            libSCEV_gf_RaceSupplyRegisterUnit(lv_player, lv_unit);
        }

    }

    return true;
}

