//--------------------------------------------------------------------------------------------------
// Trigger: LegacySelection:Dragging
//--------------------------------------------------------------------------------------------------
bool libSCEV_gt_LegacySelectionDragging_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_player;
    point lv_startPos;
    point lv_currPos;
    const int lv_dragThreshold = 10;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_player = EventPlayer();

    // Conditions
    if (testConds) {
        if (!((libSCEV_gv_legacySelectionMouseDown[lv_player] == true))) {
            return false;
        }

        if (!((libSCEV_gv_legacySelectionDragging[lv_player] == false))) {
            return false;
        }

        if (!((libSCEV_gv_legacySelectionDragStart[lv_player] != null))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    lv_startPos = libSCEV_gv_legacySelectionDragStart[lv_player];
    lv_currPos = Point(EventMouseMovedPosXUI(), EventMouseMovedPosYUI());
    if (((AbsI((FixedToInt(PointGetX(lv_startPos)) - FixedToInt(PointGetX(lv_currPos)))) > lv_dragThreshold) || (AbsI((FixedToInt(PointGetY(lv_startPos)) - FixedToInt(PointGetY(lv_currPos)))) > lv_dragThreshold))) {
        libSCEV_gv_legacySelectionDragging[lv_player] = true;
    }

    return true;
}

//--------------------------------------------------------------------------------------------------
void libSCEV_gt_LegacySelectionDragging_Init () {
    libSCEV_gt_LegacySelectionDragging = TriggerCreate("libSCEV_gt_LegacySelectionDragging_Func");
    TriggerEnable(libSCEV_gt_LegacySelectionDragging, false);
    TriggerAddEventMouseMoved(libSCEV_gt_LegacySelectionDragging, c_playerAny);
}

//--------------------------------------------------------------------------------------------------
// Trigger: LegacySelection:UnitHighlighted
//--------------------------------------------------------------------------------------------------
bool libSCEV_gt_LegacySelectionUnitHighlighted_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_player;
    unit lv_unit;
    bool lv_isStructure;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_player = EventPlayer();
    lv_unit = EventUnit();

    // Actions
    if (!runActions) {
        return true;
    }

    lv_isStructure = UnitTypeTestAttribute(UnitGetType(lv_unit), c_unitAttributeStructure);
    while ((UnitIsValid(lv_unit) == true) && (ValidatorExecute("IsHighlighted", lv_unit, lv_unit) == 0)) {
        if ((lv_isStructure == true) && ((libSCEV_gv_legacySelectionDragging[lv_player] == true) || ((libSCEV_gv_legacySelectionShiftDown[lv_player] == true) && (UnitGroupCount(libSCEV_gv_legacySelectionSelectedUnits[lv_player], c_unitCountAlive) > 0)))) {
            PlayerCreateEffectUnit(lv_player, "LegacySelection@UnitHighlightedClear", lv_unit);
        }
        else {
            BehaviorAddToSharedTrackedUnitList("LegacySelection@UnitHighlighted", lv_unit);
        }
        Wait(0.0625, c_timeGame);
    }
    if ((UnitIsValid(lv_unit) == true)) {
        PlayerCreateEffectUnit(lv_player, "LegacySelection@UnitHighlightedClear", lv_unit);
    }

    return true;
}

