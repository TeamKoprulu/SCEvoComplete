        libNtve_gf_SetDialogItemToggled(libSCEV_gv_difficultyOptionsPresetButton[3], true, lp_players);
        return ;
    }
    libSCEV_gf_DifficultyOptionsUncheckOptions(lp_players);
    auto7764C351_userType = "DifficultyPresets";
    auto7764C351_instance = lp_preset;
    auto7764C351_field = "Options";
    auto7764C351_i = 1;
    for ( ; auto7764C351_i <= UserDataFieldValueCount(auto7764C351_userType,auto7764C351_field) ; auto7764C351_i += 1 ) {
        lv_instance = UserDataGetUserInstance(auto7764C351_userType,auto7764C351_instance,auto7764C351_field, auto7764C351_i);
        lv_checkBox = libSCEV_gf_DifficultyOptionsGetOptionCheckBox(lv_instance);
        if ((lv_checkBox != c_invalidDialogControlId)) {
            libNtve_gf_SetDialogItemChecked(lv_checkBox, true, lp_players);
        }

    }
}

