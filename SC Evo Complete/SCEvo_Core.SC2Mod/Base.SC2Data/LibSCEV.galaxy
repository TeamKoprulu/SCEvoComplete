        TriggerEnable(libSCEV_gt_RaceSupplyTempMindControl_ConstructStart, lp_onOff);
    }

}

void libSCEV_gf_RaceSupplySyncAvailable (int lp_player, int lp_raceGroup) {
    // Variable Declarations
    fixed lv_used;
    fixed lv_max;
    fixed lv_reserved;
    fixed lv_available;
    playergroup lv_playerGroup;
    string lv_supplyString;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_playerGroup = PlayerGroupSingle(lp_player);
    lv_supplyString = "";

    // Implementation
    lv_used = libSCEV_gv_raceSupplyData[lp_player][lp_raceGroup].lv_used;
    lv_max = libSCEV_gv_raceSupplyData[lp_player][lp_raceGroup].lv_max;
    if ((lv_max > libSCEV_gv_raceSupplyData[lp_player][lp_raceGroup].lv_ceiling)) {
        lv_max = libSCEV_gv_raceSupplyData[lp_player][lp_raceGroup].lv_ceiling;
    }

    lv_reserved = libSCEV_gv_raceSupplyData[lp_player][lp_raceGroup].lv_reserved;
    lv_available = (lv_max - (lv_used + lv_reserved));
    if ((lv_available < 0.0)) {
        lv_available = 0.0;
    }

    if (((lv_used + lv_reserved) > lv_max)) {
        libNtve_gf_SetDialogItemColor(libSCEV_gv_raceSupplyLabel[lp_raceGroup], Color(100.00, 0.00, 0.00), lv_playerGroup);
    }
    else {
        libNtve_gf_SetDialogItemColor(libSCEV_gv_raceSupplyLabel[lp_raceGroup], Color(100,100,100), lv_playerGroup);
    }
    lv_supplyString = IntToString(FixedToInt(Ceiling((lv_used + lv_reserved))));
    if ((lv_max == 0.0)) {
        libNtve_gf_SetDialogItemText(libSCEV_gv_raceSupplyLabel[lp_raceGroup], StringToText(lv_supplyString), lv_playerGroup);
    }
    else {
        libNtve_gf_SetDialogItemText(libSCEV_gv_raceSupplyLabel[lp_raceGroup], StringToText((lv_supplyString + "/" + IntToString(FixedToInt(lv_max)))), lv_playerGroup);
    }
    if ((lp_raceGroup == libSCEV_ge_RaceSupplyGroup_Secondary)) {
        PlayerModifyPropertyInt(lp_player, c_playerPropTerrazine, c_playerPropOperSetTo, FixedToInt(lv_available));
    }
    else {
        PlayerModifyPropertyInt(lp_player, c_playerPropCustom, c_playerPropOperSetTo, FixedToInt(lv_available));
    }
}

