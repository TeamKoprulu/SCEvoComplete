    unit lv_unit;

    // Automatic Variable Declarations
    // Variable Initialization

    // Actions
    if (!runActions) {
        return true;
    }

    lv_unit = EventUnitProgressUnit();
    if ((UnitIsAlive(lv_unit) == false)) {
        lv_unit = EventUnit();
    }
    else {
        if (((UnitGetType(lv_unit) == "ScarabSCBW@Dummy") || (UnitGetType(lv_unit) == "InterceptorSCBW") || (UnitGetType(lv_unit) == "Interceptor"))) {
            return true;
        }

    }
    if ((UnitIsAlive(lv_unit) == true)) {
        libNtve_gf_CreatePingFacingAngle(PlayerGroupSingle(UnitGetOwner(lv_unit)), "PingSimple", UnitGetPosition(lv_unit), ColorWithAlpha(0.00, 50.20, 0.00, 0.00), 1.0, 270.0);
    }

    return true;
}

