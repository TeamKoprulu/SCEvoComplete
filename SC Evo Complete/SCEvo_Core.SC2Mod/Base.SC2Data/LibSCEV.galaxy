void libSCEV_gf_RaceSupplyActivateRace (int lp_player, string lp_race, int lp_raceGroup) {
    // Automatic Variable Declarations
    // Implementation
    if ((lp_raceGroup < 0)) {
        return ;
    }

    if ((libSCEV_gf_RaceSupplyIsRaceInitialized(lp_race) == false)) {
        libSCEV_gf_RaceSupplyInitRace(lp_race);
        libSCEV_gf_RaceSupplyCancelQueues(lp_player, lp_raceGroup);
    }

    if ((PlayerGroupHasPlayer(libSCEV_gv_raceSupplyPlayers, lp_player) == false)) {
        PlayerGroupAdd(libSCEV_gv_raceSupplyPlayers, lp_player);
    }

    if ((DialogControlIsVisible(libSCEV_gv_raceSupplyLabel[lp_raceGroup], lp_player) == false)) {
        DialogControlSetVisible(libSCEV_gv_raceSupplyLabel[lp_raceGroup], PlayerGroupSingle(lp_player), true);
    }

    if ((libSCEV_gv_raceSupplyData[lp_player][lp_raceGroup].lv_active == false)) {
        libSCEV_gv_raceSupplyData[lp_player][lp_raceGroup].lv_active = true;
        libSCEV_gf_RaceSupplyCatalogUpdate(lp_player, lp_raceGroup, false);
        libSCEV_gf_RaceSupplyRegisterAllUnits(lp_player);
    }

    if ((TriggerIsEnabled(libSCEV_gt_RaceSupplyUnitBirth) == false)) {
        libSCEV_gf_RaceSupplyToggleTriggers(true);
    }

}

