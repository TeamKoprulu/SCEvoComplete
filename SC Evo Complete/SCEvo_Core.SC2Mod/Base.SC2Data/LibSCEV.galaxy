    TriggerAddEventUnitAbility(libSCEV_gt_LegacyRefund, null, null, c_unitAbilStageCancel, false);
}

//--------------------------------------------------------------------------------------------------
// Trigger: Legacy:CopyReaverScarabs
//--------------------------------------------------------------------------------------------------
bool libSCEV_gt_LegacyCopyReaverScarabs_Func (bool testConds, bool runActions) {
    // Variable Declarations
    const string lv_hallucinationAmmo = "HallucinationAmmo";
    const string lv_hallucinationCount = "HallucinationCount";
    unit lv_target;
    int lv_ammoCount;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_target = EventPlayerEffectUsedUnit(c_effectUnitTarget);

    // Conditions
    if (testConds) {
        if (!((UnitIsValid(lv_target) == true))) {
            return false;
        }

        if (!((UnitGetType(lv_target) == "ReaverSCBW"))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    if ((EventPlayerEffectUsed() == "HighTemplarSCBWHallucination@SetInitial")) {
        lv_ammoCount = UnitMagazineCount(lv_target, "ReaverSCBWHangar");
        if ((lv_ammoCount > 0)) {
            DataTableSetInt(true, lv_hallucinationCount, CatalogFieldValueGetAsInt(c_gameCatalogEffect, "HighTemplarSCBWHallucination@CU", "SpawnCount", UnitGetOwner(EventPlayerEffectUsedUnit(c_effectUnitCaster))));
            DataTableSetInt(true, lv_hallucinationAmmo, lv_ammoCount);
        }

        return true;
    }
    else if ((DataTableValueExists(true, lv_hallucinationAmmo) == true)) {
        UnitMagazineArm(lv_target, AbilityCommand("ReaverSCBWHangar", 0), DataTableGetInt(true, lv_hallucinationAmmo));
        DataTableSetInt(true, lv_hallucinationCount, (DataTableGetInt(true, lv_hallucinationCount) - 1));
        if ((DataTableGetInt(true, lv_hallucinationCount) <= 0)) {
            DataTableValueRemove(true, lv_hallucinationAmmo);
            DataTableValueRemove(true, lv_hallucinationCount);
        }

    }
    return true;
}

//--------------------------------------------------------------------------------------------------
void libSCEV_gt_LegacyCopyReaverScarabs_Init () {
    libSCEV_gt_LegacyCopyReaverScarabs = TriggerCreate("libSCEV_gt_LegacyCopyReaverScarabs_Func");
    TriggerEnable(libSCEV_gt_LegacyCopyReaverScarabs, false);
    TriggerAddEventPlayerEffectUsed(libSCEV_gt_LegacyCopyReaverScarabs, c_playerAny, "HighTemplarSCBWHallucination@SetInitial");
    TriggerAddEventPlayerEffectUsed(libSCEV_gt_LegacyCopyReaverScarabs, c_playerAny, "HighTemplarSCBWHallucination@CopyScarabsTrigger");
}

//--------------------------------------------------------------------------------------------------
// Trigger: Legacy:Repair
//--------------------------------------------------------------------------------------------------
bool libSCEV_gt_LegacyRepair_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unit lv_target;
    int lv_lowestCost;
    int lv_targetMineralCost;
    int lv_targetVespeneCost;
    int lv_mineralCost;
    int lv_vespeneCost;
    string lv_gameLink;
    int lv_buildTimeFrames;
    fixed lv_maxLife;
    int lv_constructRate;
    fixed lv_timeCost;
    const int lv_FPS = 16;
    const fixed lv_gameSpeedDelta = 0.9333;
    int lv_costRate;
    int lv_maxLifeScaled;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_target = EventUnit();
    lv_gameLink = "";

    // Conditions
    if (testConds) {
        if (!((UnitIsValid(lv_target) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    lv_gameLink = (UnitGetType(lv_target));
    lv_targetMineralCost = CatalogFieldValueGetAsInt(c_gameCatalogUnit, lv_gameLink, "CostResource[" + IntToString(0) + "]", c_playerAny);
    lv_targetVespeneCost = CatalogFieldValueGetAsInt(c_gameCatalogUnit, lv_gameLink, "CostResource[" + IntToString(1) + "]", c_playerAny);
    if ((lv_targetVespeneCost == 0)) {
        lv_lowestCost = lv_targetMineralCost;
    }
    else {
        lv_lowestCost = MinI(lv_targetMineralCost, lv_targetVespeneCost);
    }
    if ((lv_lowestCost <= 0.0)) {
        return true;
    }

    lv_buildTimeFrames = CeilingI(((libNtve_gf_CatalogFieldValueGetAsReal(c_gameCatalogUnit, lv_gameLink, "BuildTime", c_playerAny) / lv_gameSpeedDelta) * lv_FPS));
    if ((lv_buildTimeFrames <= 0)) {
        return true;
    }

    lv_maxLife = UnitGetPropertyFixed(lv_target, c_unitPropLifeMax, c_unitPropCurrent);
    lv_maxLifeScaled = (FixedToInt(lv_maxLife) * 256);
    lv_constructRate = CeilingI(((0.9 * lv_maxLifeScaled) / lv_buildTimeFrames));
    lv_costRate = (lv_lowestCost * lv_constructRate);
    lv_timeCost = ((lv_maxLifeScaled * 3) / lv_costRate);
    lv_timeCost = Ceiling(lv_timeCost);
    if ((lv_timeCost > 0.0)) {
        if ((lv_lowestCost == lv_targetMineralCost)) {
            lv_mineralCost = 1;
            lv_vespeneCost = (lv_targetVespeneCost / lv_targetMineralCost);
        }
        else {
            lv_mineralCost = (lv_targetMineralCost / lv_targetVespeneCost);
            lv_vespeneCost = 1;
        }
    }
    else {
        if ((lv_targetMineralCost == 0)) {
            lv_mineralCost = 0;
        }
        else {
            lv_mineralCost = 1;
        }
        if ((lv_targetVespeneCost == 0)) {
            lv_vespeneCost = 0;
        }
        else {
            lv_vespeneCost = 1;
        }
        lv_timeCost = 1.0;
    }
    UnitBehaviorEffectTreeSetUserData(lv_target, EventUnitBehavior(), "RepairCycleCount", lv_timeCost);
    UnitBehaviorEffectTreeSetUserData(lv_target, EventUnitBehavior(), "RepairCycleMinerals", libNtve_gf_ArithmeticIntClamp(lv_mineralCost, 0, 5));
    UnitBehaviorEffectTreeSetUserData(lv_target, EventUnitBehavior(), "RepairCycleVespene", libNtve_gf_ArithmeticIntClamp(lv_vespeneCost, 0, 5));
    return true;
}

