//--------------------------------------------------------------------------------------------------
// Trigger: DifficultyOptions:LimitedRally
//--------------------------------------------------------------------------------------------------
bool libSCEV_gt_DifficultyOptionsLimitedRally_Func (bool testConds, bool runActions) {
    // Variable Declarations
    bool lv_scriptControlled;
    unit lv_unit;
    order lv_order;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_unit = EventUnit();
    lv_order = EventUnitOrder();

    // Conditions
    if (testConds) {
        if (!((OrderGetFlag(lv_order, c_cmdQueued) == true))) {
            return false;
        }

        if (!((PlayerGroupHasPlayer(libSCEV_gv_difficultyOptionsLimitedRallyPlayers, EventPlayer()) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    lv_scriptControlled = AIIsScriptControlled(lv_unit);
    OrderSetFlag(lv_order, c_cmdQueued, false);
    OrderSetFlag(lv_order, c_cmdScript, true);
    UnitIssueOrder(lv_unit, lv_order, c_orderQueueReplace);
    if ((PlayerType(UnitGetOwner(lv_unit)) == c_playerTypeComputer) && (lv_scriptControlled == false)) {
        AISetUnitScriptControlled(lv_unit, false);
    }

    return true;
}

