// Trigger: RaceSupply:FastBuildDetector
//--------------------------------------------------------------------------------------------------
bool libSCEV_gt_RaceSupplyFastBuildDetector_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_p;
    string lv_paramPlayer;

    // Automatic Variable Declarations
    playergroup autoEE8F10CC_g;

    // Variable Initialization
    lv_paramPlayer = TriggerEventParamName(libSCEV_gv_raceSupplyFastBuildEvent, "Player");

    // Conditions
    if (testConds) {
        if (!((GameCheatsEnabled(c_gameCheatCategoryPublic) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    if ((DataTableValueExists(false, lv_paramPlayer) == true)) {
        if (((DataTableGetInt(false, lv_paramPlayer) < 0) || (DataTableGetInt(false, lv_paramPlayer) > libSCEV_gv_mAX_PLAYERS))) {
            autoEE8F10CC_g = PlayerGroupAll();
            lv_p = -1;
            while (true) {
                lv_p = PlayerGroupNextPlayer(autoEE8F10CC_g, lv_p);
                if (lv_p < 0) { break; }
                libSCEV_gv_raceSupplyFastBuildEnabled[lv_p] = !(libSCEV_gv_raceSupplyFastBuildEnabled[lv_p]);
            }
            return true;
        }
        else {
            lv_p = DataTableGetInt(false, lv_paramPlayer);
        }
    }
    else {
        lv_p = EventPlayer();
    }
    libSCEV_gv_raceSupplyFastBuildEnabled[lv_p] = !(libSCEV_gv_raceSupplyFastBuildEnabled[lv_p]);
    return true;
}

