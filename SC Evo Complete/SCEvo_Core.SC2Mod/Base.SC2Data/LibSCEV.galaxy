//--------------------------------------------------------------------------------------------------
bool libSCEV_gt_LegacyCheatFoW_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_targetPlayer;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_targetPlayer = DataTableGetInt(false, TriggerEventParamName(EventGenericName(), "TargetPlayer"));

    // Conditions
    if (testConds) {
        if (!((GameIsOnline() == false))) {
            return false;
        }

        if (!((GameCheatsEnabled(c_gameCheatCategoryPublic) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    if ((libSCEV_gf_LegacyCheatActivated("FogOfWar", lv_targetPlayer) == true)) {
        VisEnable(c_visTypeFog, false);
    }
    else {
        VisEnable(c_visTypeFog, true);
    }
    return true;
}

//--------------------------------------------------------------------------------------------------
void libSCEV_gt_LegacyCheatFoW_Init () {
    libSCEV_gt_LegacyCheatFoW = TriggerCreate("libSCEV_gt_LegacyCheatFoW_Func");
    libSCEV_gf_LegacyCheatEvent(libSCEV_gt_LegacyCheatFoW, "FogOfWar");
}

//--------------------------------------------------------------------------------------------------
// Trigger: LegacyCheat:Reveal
//--------------------------------------------------------------------------------------------------
bool libSCEV_gt_LegacyCheatReveal_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_targetPlayer;
    string lv_globalRevealer;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_targetPlayer = DataTableGetInt(false, TriggerEventParamName(EventGenericName(), "TargetPlayer"));
    lv_globalRevealer = ("GlobalRevealer" + IntToString(lv_targetPlayer));

    // Conditions
    if (testConds) {
        if (!((GameIsOnline() == false))) {
            return false;
        }

        if (!((GameCheatsEnabled(c_gameCheatCategoryPublic) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    if ((libSCEV_gf_LegacyCheatActivated("MapReveal", lv_targetPlayer) == true)) {
        if ((DataTableValueExists(true, lv_globalRevealer) == false)) {
            VisRevealerCreate(lv_targetPlayer, RegionEntireMap());
            DataTableSetRevealer(true, lv_globalRevealer, VisRevealerLastCreated());
        }

        VisRevealerEnable(DataTableGetRevealer(true, lv_globalRevealer), true);
    }
    else {
        VisRevealerEnable(DataTableGetRevealer(true, lv_globalRevealer), false);
    }
    return true;
}

//--------------------------------------------------------------------------------------------------
void libSCEV_gt_LegacyCheatReveal_Init () {
    libSCEV_gt_LegacyCheatReveal = TriggerCreate("libSCEV_gt_LegacyCheatReveal_Func");
    libSCEV_gf_LegacyCheatEvent(libSCEV_gt_LegacyCheatReveal, "MapReveal");
}

//--------------------------------------------------------------------------------------------------
// Trigger: LegacySelection:ControlGroupAppend
//--------------------------------------------------------------------------------------------------
bool libSCEV_gt_LegacySelectionControlGroupAppend_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_player;
    int lv_groupIndex;
    unitgroup lv_merged;
    unitgroup lv_pruned;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_player = EventPlayer();
    lv_groupIndex = libSCEV_gf_LegacySelectionGetControlGroupIndex(EventHotkeyPressed());

    // Conditions
    if (testConds) {
        if (!((lv_groupIndex != -1))) {
            return false;
        }

        if (!((UnitGroupCount(UnitGroupSelected(lv_player), c_unitCountAlive) > 0))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    lv_merged = SCBW_MergeUnitGroups(libSCEV_gv_legacySelectionControlGroup[lv_groupIndex][lv_player], UnitControlGroup(lv_player, lv_groupIndex), true);
    lv_pruned = SCBW_PruneUnitSelectionGroup(lv_merged, libSCEV_gv_legacySelectionLimit, libSCEV_gv_legacySelectionLimitStructure, true);
    if ((SCBW_UnitGroupsEqual(lv_merged, lv_pruned) == false)) {
        UnitControlGroupClear(lv_player, lv_groupIndex);
        UnitControlGroupAddUnits(lv_player, lv_groupIndex, lv_pruned);
    }

    return true;
}

//--------------------------------------------------------------------------------------------------
void libSCEV_gt_LegacySelectionControlGroupAppend_Init () {
    libSCEV_gt_LegacySelectionControlGroupAppend = TriggerCreate("libSCEV_gt_LegacySelectionControlGroupAppend_Func");
    TriggerEnable(libSCEV_gt_LegacySelectionControlGroupAppend, false);
}

//--------------------------------------------------------------------------------------------------
// Trigger: LegacySelection:ControlGroupAssign
//--------------------------------------------------------------------------------------------------
bool libSCEV_gt_LegacySelectionControlGroupAssign_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_player;
    int lv_groupIndex;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_player = EventPlayer();
    lv_groupIndex = libSCEV_gf_LegacySelectionGetControlGroupIndex(EventHotkeyPressed());

    // Conditions
    if (testConds) {
        if (!((lv_groupIndex != -1))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    libSCEV_gv_legacySelectionControlGroup[lv_groupIndex][lv_player] = SCBW_PruneUnitSelectionGroup(UnitGroupSelected(lv_player), libSCEV_gv_legacySelectionLimit, libSCEV_gv_legacySelectionLimitStructure, true);
    if ((SCBW_UnitGroupsEqual(libSCEV_gv_legacySelectionControlGroup[lv_groupIndex][lv_player], UnitControlGroup(lv_player, lv_groupIndex)) == false)) {
        UnitControlGroupClear(lv_player, lv_groupIndex);
        UnitControlGroupAddUnits(lv_player, lv_groupIndex, libSCEV_gv_legacySelectionControlGroup[lv_groupIndex][lv_player]);
    }

    return true;
}

