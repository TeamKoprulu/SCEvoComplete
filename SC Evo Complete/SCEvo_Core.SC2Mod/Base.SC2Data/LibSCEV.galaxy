    // Variable Declarations
    int lv_player;
    int lv_raceGroup;
    fixed lv_foodValue;
    unit lv_producer;
    unit lv_trained;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_producer = EventUnit();

    // Conditions
    if (testConds) {
        if (!((UnitIsValid(lv_producer) == true))) {
            return false;
        }

        if (!((libSCEV_gv_raceSupplyActivated[UnitGetOwner(lv_producer)] == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    lv_player = UnitGetOwner(lv_producer);
    lv_trained = EventUnitProgressUnit();
    lv_raceGroup = libSCEV_gf_RaceSupplyGetRaceGroupFromUnit(lv_trained, lv_player);
    if ((libSCEV_gf_RaceSupplyRaceGroupIsActive(lv_player, lv_raceGroup) == false)) {
        return true;
    }

    lv_foodValue = libSCEV_gf_RaceSupplyGetFoodCost(lv_trained);
    if ((lv_foodValue > 0.0)) {
