bool libSCEV_gt_DifficultyOptionsBuildSingleSelect_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_newLevel;

    // Automatic Variable Declarations
    // Variable Initialization

    // Actions
    if (!runActions) {
        return true;
    }

    lv_newLevel = BoolToInt((UnitGroupCount(UnitGroupSelected(EventPlayer()), c_unitCountAlive) > 1));
    if ((TechTreeUpgradeCount(EventPlayer(), "SCBW_MultipleUnitsSelected", c_techCountCompleteOnly) != lv_newLevel)) {
        libNtve_gf_SetUpgradeLevelForPlayer(EventPlayer(), "SCBW_MultipleUnitsSelected", lv_newLevel);
    }

    return true;
}

