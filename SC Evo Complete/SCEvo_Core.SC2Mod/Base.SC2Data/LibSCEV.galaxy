// Trigger: LegacySelection:Uncontrollable
//--------------------------------------------------------------------------------------------------
bool libSCEV_gt_LegacySelectionUncontrollable_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unit lv_unit;
    order lv_order;
    int lv_orderPlayer;
    bool lv_restoreAIControl;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_unit = EventUnit();
    lv_orderPlayer = OrderGetPlayer(EventUnitOrder());

    // Conditions
    if (testConds) {
        if (!((OrderGetFlag(EventUnitOrder(), c_cmdUser) == true))) {
            return false;
        }

        if (!((OrderGetFlag(EventUnitOrder(), c_cmdScript) == false))) {
            return false;
        }

        if (!((libSCEV_gv_legacySelectionSelectedUnits[lv_orderPlayer] != null))) {
            return false;
        }

        if (!((UnitGroupHasUnit(libSCEV_gv_legacySelectionSelectedUnits[lv_orderPlayer], lv_unit) == false))) {
            return false;
        }

        if (!((UnitGroupHasUnit(UnitGroupSelected(lv_orderPlayer), lv_unit) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    if ((EventPlayer() != lv_orderPlayer)) {
        if ((PlayerType(EventPlayer()) == c_playerTypeComputer) && (AIIsScriptControlled(lv_unit) == false)) {
            lv_restoreAIControl = true;
        }

    }

    lv_order = Order(AbilityCommand("stop", 0));
    OrderSetFlag(lv_order, c_cmdScript, true);
    if ((UnitOrderIsValid(lv_unit, lv_order) == true)) {
        UnitIssueOrder(lv_unit, lv_order, c_orderQueueReplace);
    }

    libSCEV_gf_LegacySelectionRestoreUnitOrders(lv_unit);
    libSCEV_gf_LegacySelectionSaveUnitOrders(lv_unit);
    if ((lv_restoreAIControl == true)) {
        AISetUnitScriptControlled(lv_unit, false);
    }

    return true;
}

