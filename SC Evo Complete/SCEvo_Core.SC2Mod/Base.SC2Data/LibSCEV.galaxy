//--------------------------------------------------------------------------------------------------
// Trigger: Legacy:DisablePushing
//--------------------------------------------------------------------------------------------------
bool libSCEV_gt_LegacyDisablePushing_Func (bool testConds, bool runActions) {
    // Variable Declarations
    int lv_n;
    int lv_i;

    // Automatic Variable Declarations
    const int auto7697C450_n = 14;
    int auto7697C450_i;
    const int auto259DF3FF_n = 14;
    int auto259DF3FF_i;

    // Variable Initialization
    lv_n = 1;
    lv_i = 1;

    // Actions
    if (!runActions) {
        return true;
