//--------------------------------------------------------------------------------------------------
// Trigger: DifficultyOptions:BuildSingleQueue
//--------------------------------------------------------------------------------------------------
bool libSCEV_gt_DifficultyOptionsBuildSingleQueue_Func (bool testConds, bool runActions) {
    // Variable Declarations
    order lv_triggeringOrder;
    abilcmd lv_abilCommand;
    const int lv_maxOrderCount = 31;
    int lv_p;
    unit lv_unit;
    order[lv_maxOrderCount + 1] lv_ord;
    int lv_i;
    int lv_nonBuildOrders;
    int lv_buildOrdersFound;
    bool lv_buildOrderFirstOrder;
    order lv_currentOrder;

    // Automatic Variable Declarations
    int auto007EE838_ae;
    const int auto007EE838_ai = 1;
    int autoA7E8F1BE_ae;
    const int autoA7E8F1BE_ai = 1;

    // Variable Initialization
    lv_triggeringOrder = EventUnitOrder();
    lv_abilCommand = OrderGetAbilityCommand(lv_triggeringOrder);
    lv_p = UnitGetOwner(EventUnit());
    lv_unit = EventUnit();

    // Conditions
    if (testConds) {
        if (!((PlayerType(lv_p) == c_playerTypeUser))) {
            return false;
        }

        if (!((UnitTypeTestFlag(UnitGetType(lv_unit), c_unitFlagWorker) == true))) {
            return false;
        }

        if (!((AbilityClass(AbilityCommandGetAbility(OrderGetAbilityCommand(lv_triggeringOrder))) == c_classIdCAbilBuild))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    TriggerEnable(TriggerGetCurrent(), false);
    auto007EE838_ae = (UnitOrderCount(lv_unit) - 1);
    lv_i = 0;
    for ( ; ( (auto007EE838_ai >= 0 && lv_i <= auto007EE838_ae) || (auto007EE838_ai < 0 && lv_i >= auto007EE838_ae) ) ; lv_i += auto007EE838_ai ) {
        lv_currentOrder = UnitOrder(lv_unit, lv_i);
        if ((AbilityClass(AbilityCommandGetAbility(OrderGetAbilityCommand(lv_currentOrder))) != c_classIdCAbilBuild)) {
            lv_ord[lv_nonBuildOrders] = lv_currentOrder;
            lv_nonBuildOrders += 1;
        }
        else {
            lv_buildOrdersFound += 1;
            if ((lv_i == 0)) {
                lv_buildOrderFirstOrder = true;
            }

        }
    }
    if ((lv_buildOrdersFound > 1)) {
        if ((lv_nonBuildOrders == 0)) {
            UnitIssueOrder(lv_unit, Order(AbilityCommand("stop", 0)), c_orderQueueReplace);
            if ((ValidatorExecute("SCVSCBW@Building", lv_unit, lv_unit) != 0)) {
                UnitIssueOrder(lv_unit, lv_triggeringOrder, c_orderQueueReplace);
            }

        }
        else {
            UnitIssueOrder(lv_unit, Order(AbilityCommand("stop", 0)), c_orderQueueReplace);
            autoA7E8F1BE_ae = (lv_nonBuildOrders - 1);
            lv_i = 0;
            for ( ; ( (autoA7E8F1BE_ai >= 0 && lv_i <= autoA7E8F1BE_ae) || (autoA7E8F1BE_ai < 0 && lv_i >= autoA7E8F1BE_ae) ) ; lv_i += autoA7E8F1BE_ai ) {
                if ((lv_i == 0)) {
                    UnitIssueOrder(lv_unit, lv_ord[lv_i], c_orderQueueReplace);
                }
                else {
                    UnitIssueOrder(lv_unit, lv_ord[lv_i], c_orderQueueAddToEnd);
                }
            }
            UnitIssueOrder(lv_unit, lv_triggeringOrder, c_orderQueueAddToEnd);
        }
    }

    TriggerEnable(TriggerGetCurrent(), true);
    return true;
}

