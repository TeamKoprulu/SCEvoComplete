void libSCEV_gt_LegacySelectionUnitHighlighted_Init () {
    libSCEV_gt_LegacySelectionUnitHighlighted = TriggerCreate("libSCEV_gt_LegacySelectionUnitHighlighted_Func");
    TriggerEnable(libSCEV_gt_LegacySelectionUnitHighlighted, false);
}

//--------------------------------------------------------------------------------------------------
// Trigger: LegacySelection:UnitSelected
//--------------------------------------------------------------------------------------------------
bool libSCEV_gt_LegacySelectionUnitSelected_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unitgroup lv_newGroup;
    int lv_player;
    unitgroup lv_selectedUnits;
    bool lv_isStructure;
    bool lv_forward;
    unit lv_highlightedUnit;

    // Automatic Variable Declarations
    unitgroup auto5F71AD89_g;
    int auto5F71AD89_u;
    unit auto5F71AD89_var;

    // Variable Initialization
    lv_player = EventPlayer();
    lv_selectedUnits = UnitGroupSelected(lv_player);

    // Conditions
    if (testConds) {
        if (!((PlayerType(lv_player) == c_playerTypeUser))) {
            return false;
        }

        if (!((TriggerIsEnabled(TriggerGetCurrent()) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    TriggerEnable(TriggerGetCurrent(), false);
    lv_highlightedUnit = UnitGroupUnit(UnitGetTrackedUnitGroup(null, "LegacySelection@UnitHighlighted"), 1);
    lv_isStructure = UnitTypeTestAttribute(UnitGetType(EventUnit()), c_unitAttributeStructure);
    if ((libSCEV_gv_legacySelectionShiftDown[lv_player] == true) && (lv_isStructure == false)) {
        lv_newGroup = SCBW_MergeUnitGroups(libSCEV_gv_legacySelectionSelectedUnits[lv_player], lv_selectedUnits, true);
    }
    else if ((libSCEV_gv_legacySelectionCtrlDown[lv_player] == true) && (lv_isStructure == true) && (lv_highlightedUnit == EventUnit())) {
        lv_newGroup = SCBW_MergeUnitGroups(lv_selectedUnits, libSCEV_gv_legacySelectionSelectedUnits[lv_player], false);
    }
    else if ((libSCEV_gv_legacySelectionCtrlDown[lv_player] == true) && (lv_isStructure == false) && (UnitGetType(EventUnit()) == UnitGetType(lv_highlightedUnit))) {
        lv_newGroup = UnitGroupEmpty();
        UnitGroupAdd(lv_newGroup, lv_highlightedUnit);
        UnitGroupAddUnitGroup(lv_newGroup, lv_selectedUnits);
    }
    else if (true) {
        lv_newGroup = lv_selectedUnits;
    }
    lv_forward = !(UnitTypeTestAttribute(UnitGetType(UnitGroupUnit(lv_newGroup, 1)), c_unitAttributeStructure));
    lv_newGroup = SCBW_PruneUnitSelectionGroup(lv_newGroup, libSCEV_gv_legacySelectionLimit, libSCEV_gv_legacySelectionLimitStructure, lv_forward);
    libSCEV_gv_legacySelectionSelectedUnits[lv_player] = lv_newGroup;
    if ((SCBW_UnitGroupsEqual(lv_selectedUnits, lv_newGroup) == false)) {
        UnitGroupRemoveUnitGroup(lv_selectedUnits, lv_newGroup);
        UnitGroupSelect(lv_selectedUnits, lv_player, false);
    }

    auto5F71AD89_g = lv_newGroup;
    auto5F71AD89_u = UnitGroupCount(auto5F71AD89_g, c_unitCountAll);
    for (;; auto5F71AD89_u -= 1) {
        auto5F71AD89_var = UnitGroupUnitFromEnd(auto5F71AD89_g, auto5F71AD89_u);
        if (auto5F71AD89_var == null) { break; }
        if ((UnitTypeTestAttribute(UnitGetType(auto5F71AD89_var), c_unitAttributeStructure) == true)) {
            PlayerCreateEffectUnit(lv_player, "LegacySelection@StructureSelectedClear", auto5F71AD89_var);
            BehaviorAddToSharedTrackedUnitList("LegacySelection@StructureSelected", auto5F71AD89_var);
        }

        BehaviorAddToSharedTrackedUnitList((("LegacySelection@SelectedUnits" + IntToString(lv_player))), auto5F71AD89_var);
    }
    libSCEV_gf_LegacySelectionRefreshUI(PlayerGroupSingle(lv_player));
    Wait(0.0, c_timeGame);
    TriggerEnable(TriggerGetCurrent(), true);
    return true;
}

//--------------------------------------------------------------------------------------------------
void libSCEV_gt_LegacySelectionUnitSelected_Init () {
    libSCEV_gt_LegacySelectionUnitSelected = TriggerCreate("libSCEV_gt_LegacySelectionUnitSelected_Func");
    TriggerEnable(libSCEV_gt_LegacySelectionUnitSelected, false);
}

//--------------------------------------------------------------------------------------------------
// Trigger: LegacySelection:UnitDeselected
//--------------------------------------------------------------------------------------------------
bool libSCEV_gt_LegacySelectionUnitDeselected_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unit lv_unit;
    int lv_player;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_unit = EventUnit();
    lv_player = EventPlayer();

    // Conditions
    if (testConds) {
        if (!((PlayerType(lv_player) == c_playerTypeUser))) {
            return false;
        }

        if (!((UnitGroupHasUnit(libSCEV_gv_legacySelectionSelectedUnits[lv_player], lv_unit) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    UnitGroupRemove(libSCEV_gv_legacySelectionSelectedUnits[lv_player], lv_unit);
    if ((UnitTypeTestAttribute(UnitGetType(lv_unit), c_unitAttributeStructure) == true)) {
        PlayerCreateEffectUnit(lv_player, "LegacySelection@StructureSelectedClear", lv_unit);
    }

    PlayerCreateEffectUnit(lv_player, (("LegacySelection@SelectedUnits" + IntToString(lv_player) + "Clear")), lv_unit);
    if ((lv_player == 1)) {
        libSCEV_gv_legacySelectionSelectedUnitCount_1 = UnitGroupCount(libSCEV_gv_legacySelectionSelectedUnits[lv_player], c_unitCountAlive);
    }
    return true;
}

//--------------------------------------------------------------------------------------------------
void libSCEV_gt_LegacySelectionUnitDeselected_Init () {
    libSCEV_gt_LegacySelectionUnitDeselected = TriggerCreate("libSCEV_gt_LegacySelectionUnitDeselected_Func");
    TriggerEnable(libSCEV_gt_LegacySelectionUnitDeselected, false);
}

//--------------------------------------------------------------------------------------------------
// Trigger: LegacySelection:UnitCreated
//--------------------------------------------------------------------------------------------------
bool libSCEV_gt_LegacySelectionUnitCreated_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unit lv_unit;
    int lv_owner;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_unit = EventUnitCreatedUnit();
    lv_owner = UnitGetOwner(lv_unit);

    // Conditions
    if (testConds) {
        if (!((UnitIsValid(lv_unit) == true))) {
            return false;
        }

        if (!((UnitFilterMatch(lv_unit, lv_owner, UnitFilter(0, 0, (1 << c_targetFilterMissile) | (1 << c_targetFilterUncommandable), (1 << (c_targetFilterDead - 32)))) == true))) {
            return false;
        }

        if (!((UnitTestState(lv_unit, c_unitStateSelectable) == true))) {
            return false;
        }

        if (!((PlayerGroupHasPlayer(libSCEV_gv_legacySelectionPlayers, lv_owner) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    BehaviorAddToSharedTrackedUnitList("LegacySelection@PlayerUnits", lv_unit);
    if ((UnitTypeTestAttribute(UnitGetType(lv_unit), c_unitAttributeStructure) == true)) {
        UnitBehaviorAddPlayer(lv_unit, "LegacySelection@Uncommandable", lv_owner, 1);
    }
    else {
        UnitBehaviorAddPlayer(lv_unit, "LegacySelection@HideWaypoints", lv_owner, 1);
    }
    return true;
}

//--------------------------------------------------------------------------------------------------
void libSCEV_gt_LegacySelectionUnitCreated_Init () {
    libSCEV_gt_LegacySelectionUnitCreated = TriggerCreate("libSCEV_gt_LegacySelectionUnitCreated_Func");
    TriggerEnable(libSCEV_gt_LegacySelectionUnitCreated, false);
    TriggerAddEventUnitCreated(libSCEV_gt_LegacySelectionUnitCreated, null, null, null);
}

//--------------------------------------------------------------------------------------------------
// Trigger: LegacySelection:OwnerChanged
//--------------------------------------------------------------------------------------------------
bool libSCEV_gt_LegacySelectionOwnerChanged_Func (bool testConds, bool runActions) {
    // Variable Declarations
    unit lv_unit;
    int lv_newOwner;

    // Automatic Variable Declarations
    // Variable Initialization
    lv_unit = EventUnit();
    lv_newOwner = EventUnitOwnerNew();

    // Conditions
    if (testConds) {
        if (!((UnitIsValid(lv_unit) == true))) {
            return false;
        }

        if (!((UnitFilterMatch(lv_unit, lv_newOwner, UnitFilter(0, 0, (1 << c_targetFilterMissile) | (1 << c_targetFilterUncommandable), (1 << (c_targetFilterDead - 32)))) == true))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    if ((PlayerGroupHasPlayer(libSCEV_gv_legacySelectionPlayers, EventUnitOwnerOld()) == true)) {
        libSCEV_gf_LegacySelectionRemoveUnitTracking(lv_unit, EventUnitOwnerOld());
    }

    if ((PlayerGroupHasPlayer(libSCEV_gv_legacySelectionPlayers, lv_newOwner) == true)) {
        BehaviorAddToSharedTrackedUnitList("LegacySelection@PlayerUnits", lv_unit);
    }

    return true;
}

//--------------------------------------------------------------------------------------------------
void libSCEV_gt_LegacySelectionOwnerChanged_Init () {
    libSCEV_gt_LegacySelectionOwnerChanged = TriggerCreate("libSCEV_gt_LegacySelectionOwnerChanged_Func");
    TriggerEnable(libSCEV_gt_LegacySelectionOwnerChanged, false);
    TriggerAddEventUnitChangeOwner(libSCEV_gt_LegacySelectionOwnerChanged, null);
