    <CActorEventMacro id="RoboticsFacilitySCBW@WarpInMacro">
        <On Terms="ActorCreation" Send="StatusSet WarpingIn 0"/>
        <!-- Shuttle -->
        <On Terms="AbilTrain.RoboticsFacilitySCBW@Train.Start; AbilTrainProduced ShuttleSCBW; !ValidateUnit HasNoPower" Send="Create ShuttleSCBW@WarpInRobotics"/>
        <On Terms="AbilTrain.RoboticsFacilitySCBW@Train.Start; AbilTrainProduced ShuttleSCBW" Send="StatusSet WarpingIn 1"/>
        <On Terms="BehaviorLevel.PowerUserQueue.Stop; Level 0; IsStatus WarpingIn 1" Send="Create ShuttleSCBW@WarpInRobotics"/>
        <On Terms="BehaviorLevel.PowerUserQueue.Start; Level 0" Target="ShuttleSCBW@WarpInRobotics" Send="Destroy"/>
        <On Terms="AbilTrain.RoboticsFacilitySCBW@Train.Cancel" Target="ShuttleSCBW@WarpInRobotics" Send="Destroy"/>
        <On Terms="AbilTrain.RoboticsFacilitySCBW@Train.Finish" Target="ShuttleSCBW@WarpInRobotics" Send="Destroy"/>
        <!-- Observer -->
        <On Terms="AbilTrain.RoboticsFacilitySCBW@Train.Start; AbilTrainProduced ObserverSCBW; !ValidateUnit HasNoPower" Send="Create ObserverSCBW@WarpInRobotics"/>
        <On Terms="AbilTrain.RoboticsFacilitySCBW@Train.Start; AbilTrainProduced ObserverSCBW" Send="StatusSet WarpingIn 1"/>
        <On Terms="BehaviorLevel.PowerUserQueue.Stop; Level 0; IsStatus WarpingIn 1" Send="Create ObserverSCBW@WarpInRobotics"/>
        <On Terms="BehaviorLevel.PowerUserQueue.Start; Level 0" Target="ObserverSCBW@WarpInRobotics" Send="Destroy"/>
        <On Terms="AbilTrain.RoboticsFacilitySCBW@Train.Cancel" Target="ObserverSCBW@WarpInRobotics" Send="Destroy"/>
        <On Terms="AbilTrain.RoboticsFacilitySCBW@Train.Finish" Target="ObserverSCBW@WarpInRobotics" Send="Destroy"/>
        <!-- Reaver -->
        <On Terms="AbilTrain.RoboticsFacilitySCBW@Train.Start; AbilTrainProduced ReaverSCBW; !ValidateUnit HasNoPower" Send="Create ReaverSCBW@WarpInRobotics"/>
        <On Terms="AbilTrain.RoboticsFacilitySCBW@Train.Start; AbilTrainProduced ReaverSCBW" Send="StatusSet WarpingIn 1"/>
        <On Terms="BehaviorLevel.PowerUserQueue.Stop; Level 0; IsStatus WarpingIn 1" Send="Create ReaverSCBW@WarpInRobotics"/>
        <On Terms="BehaviorLevel.PowerUserQueue.Start; Level 0" Target="ReaverSCBW@WarpInRobotics" Send="Destroy"/>
        <On Terms="AbilTrain.RoboticsFacilitySCBW@Train.Cancel" Target="ReaverSCBW@WarpInRobotics" Send="Destroy"/>
        <On Terms="AbilTrain.RoboticsFacilitySCBW@Train.Finish" Target="ReaverSCBW@WarpInRobotics" Send="Destroy"/>
        <!--  -->
        <On Terms="AbilTrain.RoboticsFacilitySCBW@Train.Cancel" Send="StatusSet WarpingIn 0"/>
        <On Terms="AbilTrain.RoboticsFacilitySCBW@Train.Finish" Send="StatusSet WarpingIn 0"/>
