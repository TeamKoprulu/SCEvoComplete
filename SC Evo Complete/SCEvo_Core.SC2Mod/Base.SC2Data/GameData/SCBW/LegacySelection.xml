    <CActorSimple id="LegacySelection@SelectedUnits">
        <On Terms="BehaviorStackAlias.LegacySelection.On" Send="Create"/>
        <On Terms="SupporterDestruction" Send="Destroy"/>
        <On Terms="SelectionLocalUpdate.*.Start; Selected; ValidateUnit LegacySelection@NotSelected" Send="Signal LegacySelectionHide"/>
        <On Terms="Signal.*.LegacySelectionHide; ScopeContains GroundLocalSelection" Target="GroundLocalSelection" Send="SetVisibility"/>
        <On Terms="Signal.*.LegacySelectionHide" Send="TimerSet 0.010000 LegacySelectionUpdate"/>
        <On Terms="TimerExpired; TimerName LegacySelectionUpdate" Send="Signal LegacySelectionUpdate"/>
        <On Terms="Signal.*.LegacySelectionUpdate; ScopeContains GroundLocalSelection; ValidateUnit LegacySelection@NotSelected" Target="GroundLocalSelection" Send="SetVisibility"/>
        <On Terms="Signal.*.LegacySelectionUpdate; ScopeContains GroundLocalSelection; !ValidateUnit LegacySelection@NotSelected" Target="GroundLocalSelection" Send="SetVisibility 1"/>
        <On Terms="Signal.*.LegacySelectionUpdate; Selected; ValidateUnit LegacySelection@NotSelected" Send="TimerSet 0.010000 LegacySelectionUpdate"/>
        <Supporter Subject="_Unit"/>
        <Terms value="Cap 1"/>
    </CActorSimple>
