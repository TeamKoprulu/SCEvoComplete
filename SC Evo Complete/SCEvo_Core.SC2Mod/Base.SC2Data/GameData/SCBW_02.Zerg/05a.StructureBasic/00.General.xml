    <CActorStateMonitor id="ZergBuildingSCBW@InfestedStructuresSmokeLarge">
        <On Terms="UnitCreation.InfestedCommandCenterSCBW" Send="Create"/>
        <On Terms="UnitCreation.InfestedCommandCenterSCBW@Flying" Send="Create"/>
        <On Terms="UnitCreation.InfestedCommandCenterSC2" Send="Create"/>
        <On Terms="UnitCreation.InfestedCommandCenterSC2@Flying" Send="Create"/>
        <On Terms="UnitCreation.InfestedOrbitalCommandSCBW" Send="Create"/>
        <On Terms="UnitCreation.InfestedOrbitalCommandSCBW@Flying" Send="Create"/>
        <On Terms="UnitCreation.InfestedPlanetaryFortressSCBW" Send="Create"/>
        <On Terms="StateChange; StateValid LightSmoke; StateChanged Normal" Send="Create TerranFlameSetLightSmoke"/>
        <On Terms="StateChange; StateValid HeavySmoke; StateChanged Normal" Send="Create TerranFlameSetHeavySmoke"/>
        <On Terms="StateChange; StateValid LightSmoke; !StateChanged Normal" Send="Create TerranFlameSetLightSmokeTransition"/>
        <On Terms="StateChange; StateValid HeavySmoke; !StateChanged Normal" Send="Create TerranFlameSetHeavySmokeTransition"/>
        <On Terms="StateChange; !StateValid LightSmoke" Target="TerranFlameSetLightSmoke" Send="Destroy"/>
        <On Terms="StateChange; !StateValid HeavySmoke" Target="TerranFlameSetHeavySmoke" Send="Destroy"/>
        <On Terms="StateChange; !StateValid LightSmoke" Target="TerranFlameSetLightSmokeTransition" Send="Destroy"/>
        <On Terms="StateChange; !StateValid HeavySmoke" Target="TerranFlameSetHeavySmokeTransition" Send="Destroy"/>
        <StateArray Name="Normal" Terms="ValidateUnit ZergBuildingSCBW@InfestedStructuresNormal"/>
        <StateArray Name="LightSmoke" Terms="ValidateUnit ZergBuildingSCBW@InfestedStructuresLightSmoke"/>
        <StateArray Name="HeavySmoke" Terms="ValidateUnit ZergBuildingSCBW@InfestedStructuresHeavySmoke"/>
        <StateThinkInterval value="0.5"/>
    </CActorStateMonitor>
    <CActorStateMonitor id="ZergBuildingSCBW@BloodLarge" parent="ZergBlood">
        <On Terms="UnitCreation.HatcherySCBW" Send="Create"/>
        <On Terms="UnitCreation.LairSCBW" Send="Create"/>
        <On Terms="UnitCreation.HiveSCBW" Send="Create"/>
        <On Terms="StateChange; StateValid ZergBleedLight; StateChanged ZergNormal" Send="Create ZergBloodSetBleedSmall"/>
        <On Terms="StateChange; StateValid ZergBleedHeavy; StateChanged ZergNormal" Send="Create ZergBloodSetBleedHeavy"/>
        <On Terms="StateChange; StateValid ZergBleedProfusely; StateChanged ZergNormal" Send="Create ZergBloodSetBleedProfusely"/>
        <On Terms="StateChange; StateValid ZergBleedLight; !StateChanged ZergNormal" Send="Create ZergBloodSetBleedSmall"/>
        <On Terms="StateChange; StateValid ZergBleedHeavy; !StateChanged ZergNormal" Send="Create ZergBloodSetBleedHeavy"/>
        <On Terms="StateChange; StateValid ZergBleedProfusely; !StateChanged ZergNormal" Send="Create ZergBloodSetBleedProfusely"/>
        <On Terms="StateChange; StateValid ZergNormal; StateChanged ZergBleedLight" Target="ZergBloodSetBleedSmall" Send="Destroy"/>
        <On Terms="StateChange; StateValid ZergBleedLight; StateChanged ZergBleedHeavy" Target="ZergBloodSetBleedHeavy" Send="Destroy"/>
        <On Terms="StateChange; StateValid ZergBleedHeavy; StateChanged ZergBleedProfusely" Target="ZergBloodSetBleedProfusely" Send="Destroy"/>
        <On Terms="StateChange; StateValid ZergNormal" Target="ZergBloodSetBleedSmall" Send="Destroy"/>
        <On Terms="StateChange; StateValid ZergNormal" Target="ZergBloodSetBleedHeavy" Send="Destroy"/>
        <On Terms="StateChange; StateValid ZergNormal" Target="ZergBloodSetBleedProfusely" Send="Destroy"/>
    </CActorStateMonitor>
    <CActorStateMonitor id="ZergBuildingSCBW@BloodMedium" parent="ZergBlood">
        <On Terms="UnitCreation.HydraliskDenSCBW" Send="Create"/>
        <On Terms="UnitCreation.ExtractorSCBW" Send="Create"/>
        <On Terms="UnitCreation.ExtractorSCBW@Rich" Send="Create"/>
        <On Terms="UnitCreation.SpawningPoolSCBW" Send="Create"/>
        <On Terms="UnitCreation.EvolutionChamberSCBW" Send="Create"/>
        <On Terms="UnitCreation.UltraliskCavernSCBW" Send="Create"/>
        <On Terms="UnitCreation.QueensNestSCBW" Send="Create"/>
