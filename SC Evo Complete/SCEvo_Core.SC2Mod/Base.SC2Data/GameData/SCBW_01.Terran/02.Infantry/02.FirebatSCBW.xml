    <CActorEventMacro id="FirebatSCBWWeapon@Anims">
        <Remove Terms="WeaponStop.*.AttackStop" Send="AnimBracketStop Attack"/>
        <On Terms="Effect.FirebatSCBWWeapon@CP.Start; At Caster" Send="AnimPlay Attack Attack"/>
        <On Terms="Effect.FirebatSCBWWeapon@CP.Start; At Caster; !ValidateUnit FirebatSCBWStimpack@TestBuff" Send="AnimSetTimeScale Attack 1.500000"/>
        <On Terms="UnitMovementUpdate.*.Walk" Send="AnimClear Attack 0.250000"/>
        <On Terms="Abil.attack.ReadyStop" Send="AnimClear Attack 0.250000"/>
        <On Terms="Behavior.FirebatSCBWWeapon@SuppressMovement.On" Send="MessageUpdateActivate 0"/>
        <On Terms="Behavior.FirebatSCBWWeapon@SuppressMovement.On" Send="AnimPlay Ready Stand,Ready NonLooping -1.000000 -1.000000 -1.000000 AsAutomatic 0.000000 6"/>
        <On Terms="Behavior.FirebatSCBWWeapon@SuppressMovement.Off; ValidateUnit CasterIsAnimatingWeapon" Send="TimerSet 0.180000 DelayAnim"/>
        <On Terms="Behavior.FirebatSCBWWeapon@SuppressMovement.Off; !ValidateUnit CasterIsAnimatingWeapon" Send="AnimClear Ready"/>
        <On Terms="TimerExpired; TimerName DelayAnim" Send="AnimClear Ready"/>
        <On Terms="Behavior.FirebatSCBWWeapon@SuppressMovement.Off; ValidateUnit CasterIsAnimatingWeapon" Send="MessageUpdateActivate"/>
        <On Terms="ActorUpdate; !ValidateUnit CasterIsAnimatingWeapon" Send="AnimClear Ready"/>
        <On Terms="ActorUpdate; !ValidateUnit CasterIsAnimatingWeapon" Send="MessageUpdateActivate 0"/>
        <On Terms="Behavior.FirebatSCBWWeapon@SuppressMovement.Off; ValidateUnit IsHidden" Target="FirebatSCBWWeapon@Model" Send="DestroyParticles"/>
        <On Terms="Behavior.FirebatSCBWWeapon@SuppressMovement.Off; ValidateUnit IsHidden" Target="FirebatSCBWWeapon@Model" Send="Destroy Immediate"/>
        <On Terms="UnitDeath" Target="FirebatSCBWWeapon@Model" Send="Signal Destroy"/>
    </CActorEventMacro>
