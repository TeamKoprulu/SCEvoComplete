// Classic Icons activation
bool KopruluSkinsClassicIconsActivate_Func(bool test_conds, bool run_actions){
    int player = DataTableGetInt(true, "KopruluSkinsFunction_Player");
    bool state =  DataTableGetBool(true, "KopruluSkinsFunction_State");
    DataTableValueRemove(true, "KopruluSkinsFunction_Player");
    DataTableValueRemove(true, "KopruluSkinsFunction_State");
    // Can only be enabled
    if(state == true){
        libSCEV_gf_LegacyIconsActivate(state, PlayerGroupSingle(player));
    }

    TriggerDestroy(TriggerGetCurrent());
    return true;
}

void KopruluSkinsNotificationStart (int player) {
    string race;
    bool isBWRace;

    ////
    return;
    ///

    race = PlayerRace(player);
    isBWRace = (race == "BWTe" || race == "BWPr" || race == "BWZe");

    // No skins implemented for SC2 Races yet.
    if(isBWRace == false){ return; }

    if(KopruluSkinsCalloutFrame == 0){ 
        KopruluSkinsCalloutResponses_t = TriggerCreate("KopruluSkinsCalloutResponses_Func");

        DialogControlHookupStandard(c_triggerControlTypePanel, "UIContainer/FullscreenUpperContainer/SkinsCallout");
        KopruluSkinsCalloutFrame = DialogControlLastCreated();
        DialogControlHookup(KopruluSkinsCalloutFrame, c_triggerControlTypeButton, "IgnoreButton");
        KopruluSkinsCalloutCloseButton = DialogControlLastCreated();
        TriggerAddEventDialogControl(KopruluSkinsCalloutResponses_t, c_playerAny, DialogControlLastCreated(), c_triggerControlEventTypeClick);
        // Menu button click
        TriggerAddEventDialogControl(KopruluSkinsCalloutResponses_t, c_playerAny, KopruluMenuToggleButton, c_triggerControlEventTypeClick);

        TriggerEnable(KopruluSkinsCalloutResponses_t, true);
    }

    DialogControlSetVisible(KopruluSkinsCalloutFrame, PlayerGroupSingle(player), true);

    if(gv_KopruluSkinsCalloutTimer[player] == null){
        TimerStart(TimerCreate(), 90, false, c_timeReal);
        gv_KopruluSkinsCalloutTimer[player] = TimerLastStarted();
        if(KopruluSkinsCalloutTimerExpire_t == null){
            KopruluSkinsCalloutTimerExpire_t = TriggerCreate("KopruluSkinsCalloutTimerExpire_Func");
        }
        TriggerAddEventTimer(KopruluSkinsCalloutTimerExpire_t, TimerLastStarted());
    }

}

void KopruluSkinsNotificationEnd (int player) {
    if(DialogControlIsVisible(KopruluSkinsCalloutFrame, player)){
        DialogControlSetVisible(KopruluSkinsCalloutFrame, PlayerGroupSingle(player), false);
        Extension_BankUpdateSkinVersion(player);
    }
    if(gv_KopruluSkinsCalloutTimer[player] != null){
        libNtve_gf_StopTimer(gv_KopruluSkinsCalloutTimer[player]);
        gv_KopruluSkinsCalloutTimer[player]  = null;
    }
}