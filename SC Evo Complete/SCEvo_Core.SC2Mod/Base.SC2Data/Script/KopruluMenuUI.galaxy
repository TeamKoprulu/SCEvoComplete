bool KopruluSkinsCalloutTimerExpire_Func(bool test_conds, bool run_actions){
    int i;
    int tmp_player;

    for (i = 1; i <= PlayerGroupCount(PlayerGroupActive()); i += 1) {
        tmp_player = PlayerGroupPlayer(PlayerGroupActive(), i);

        if(gv_KopruluSkinsCalloutTimer[tmp_player] == EventTimer()){
            gv_KopruluSkinsCalloutTimer[tmp_player] = null;
            if(DialogControlIsVisible(KopruluSkinsCalloutFrame, tmp_player)){
                DialogControlSetPropertyAsBool(KopruluSkinsCalloutFrame, c_triggerControlPropertyVisible, PlayerGroupSingle(tmp_player), false);
            }
            // if(DialogControlIsVisible(KopruluSkinsPanel, tmp_player)){
            //     Extension_BankUpdateSkinVersion(tmp_player);
            // }
            break;
        }
    }

    return true;
}

bool KopruluSkinsCalloutResponses_Func(bool test_conds, bool run_actions){
    playergroup players = PlayerGroupActive();
    int i;
    int player = EventPlayer();

    if(!PlayerGroupHasPlayer(players, player) || (PlayerStatus(player) != c_playerStatusActive) ) {
        return false;
    }
    
    if(EventDialogControl() == KopruluMenuToggleButton){
        // if(DialogControlIsVisible(KopruluSkinsPanel, player) == true){
        //     DialogControlSetVisible(KopruluSkinsPanel, PlayerGroupSingle(player), false);
        //     KopruluSkinsNotificationEnd(player);
        // }
        return true;
    }

    KopruluSkinsNotificationEnd(player);
    return true;
}


