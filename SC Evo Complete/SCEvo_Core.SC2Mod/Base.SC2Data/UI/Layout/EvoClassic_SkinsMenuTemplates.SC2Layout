                    <TabListItem val="$parent/ListboxItem2"/>
                    <TabListItem val="$parent/ListboxItem3"/>
                    <TabListItem val="$parent/ListboxItem4"/>
                    <TabListItem val="$parent/ListboxItem5"/>
                    <TabListItem val="$parent/ListboxItem6"/>
                    <TabListItem val="$parent/ListboxItem7"/>
                    <TabListItem val="$parent/ListboxItem8"/>
                    <TabListItem val="$parent/ListboxItem9"/>
                    <TabListItem val="$parent/ListboxItem10"/>
                    <TabListItem val="$parent/ListboxItem11"/>
                    <TabListItem val="$parent/ListboxItem12"/>
                    <TabListItem val="$parent/ListboxItem13"/>
                    <TabListItem val="$parent/ListboxItem14"/>
                </Frame>

                <Frame type="Button" name="ListboxItem1" template="EvoClassic_SkinsMenuTemplates/UnitListboxItemTemplate">
                </Frame>

                <Frame type="Button" name="ListboxItem2" template="EvoClassic_SkinsMenuTemplates/UnitListboxItemTemplate">
                    <Anchor side="Top" relative="$sibling-1" pos="Max" offset="5"/>
                </Frame>

                <Frame type="Button" name="ListboxItem3" template="EvoClassic_SkinsMenuTemplates/UnitListboxItemTemplate">
                    <Anchor side="Top" relative="$sibling-1" pos="Max" offset="5"/>
                </Frame>

                <Frame type="Button" name="ListboxItem4" template="EvoClassic_SkinsMenuTemplates/UnitListboxItemTemplate">
                    <Anchor side="Top" relative="$sibling-1" pos="Max" offset="5"/>
                </Frame>

                <Frame type="Button" name="ListboxItem5" template="EvoClassic_SkinsMenuTemplates/UnitListboxItemTemplate">
                    <Anchor side="Top" relative="$sibling-1" pos="Max" offset="5"/>
                </Frame>

                <Frame type="Button" name="ListboxItem6" template="EvoClassic_SkinsMenuTemplates/UnitListboxItemTemplate">
                    <Anchor side="Top" relative="$sibling-1" pos="Max" offset="5"/>
                </Frame>

                <Frame type="Button" name="ListboxItem7" template="EvoClassic_SkinsMenuTemplates/UnitListboxItemTemplate">
                    <Anchor side="Top" relative="$sibling-1" pos="Max" offset="5"/>
                </Frame>

                <Frame type="Button" name="ListboxItem8" template="EvoClassic_SkinsMenuTemplates/UnitListboxItemTemplate">
                    <Anchor side="Top" relative="$sibling-1" pos="Max" offset="5"/>
                </Frame>

                <Frame type="Button" name="ListboxItem9" template="EvoClassic_SkinsMenuTemplates/UnitListboxItemTemplate">
                    <Anchor side="Top" relative="$sibling-1" pos="Max" offset="5"/>
                </Frame>

                <Frame type="Button" name="ListboxItem10" template="EvoClassic_SkinsMenuTemplates/UnitListboxItemTemplate">
                    <Anchor side="Top" relative="$sibling-1" pos="Max" offset="5"/>
                </Frame>

                <Frame type="Button" name="ListboxItem11" template="EvoClassic_SkinsMenuTemplates/UnitListboxItemTemplate">
                    <Anchor side="Top" relative="$sibling-1" pos="Max" offset="5"/>
                </Frame>

                <Frame type="Button" name="ListboxItem12" template="EvoClassic_SkinsMenuTemplates/UnitListboxItemTemplate">
                    <Anchor side="Top" relative="$sibling-1" pos="Max" offset="5"/>
                </Frame>

                <Frame type="Button" name="ListboxItem13" template="EvoClassic_SkinsMenuTemplates/UnitListboxItemTemplate">
                    <Anchor side="Top" relative="$sibling-1" pos="Max" offset="5"/>
                </Frame>

                <Frame type="Button" name="ListboxItem14" template="EvoClassic_SkinsMenuTemplates/UnitListboxItemTemplate">
                    <Anchor side="Top" relative="$sibling-1" pos="Max" offset="5"/>
                </Frame>
            </Frame>
            <Frame type="Image" name="ScrollBarBackground" template="EvoClassic_StandardTemplates/ScrollBarBackgroundTemplate">
                <Visible val="{$parent/ScrollBar/@Visible}"/>
                <CollapseLayout val="True"/>
            </Frame>
    
            <Frame type="ScrollBar" name="ScrollBar" template="EvoClassic_StandardTemplates/ScrollBarTemplate">
                <Anchor side="Top" relative="$parent" pos="Min" offset="0"/>
                <Anchor side="Bottom" relative="$parent" pos="Max" offset="-15"/>
                <Anchor side="Right" relative="$parent" pos="Max" offset="-12"/>
            </Frame>

            <Frame type="Frame" name="ContainerFrameBottomAnchor">
                <Anchor side="Bottom" relative="$parent/ContainerFrame/ListboxItem14" pos="Max" offset="0"/>
                <Anchor side="Left" relative="$parent" pos="Min" offset="0"/>
                <Anchor side="Right" relative="$parent" pos="Max" offset="0"/>
                <Height val="1"/>
            </Frame>
        </Frame>
    </Frame>

    <Frame type="Frame" name="SkinPreviewPanelTemplate">
        <Anchor side="Top" relative="$parent/Divider" pos="Max" offset="0"/>
        <Anchor side="Bottom" relative="$parent" pos="Max" offset="0"/>
        <Anchor side="Right" relative="$parent" pos="Max" offset="0"/>

        <Width val="380"/>

        <Frame type="Image" name="DividerImage">
            <Anchor side="Top" relative="$parent" pos="Min" offset="0"/>
            <Anchor side="Bottom" relative="$parent" pos="Max" offset="0"/>
            <Anchor side="Left" relative="$parent" pos="Min" offset="0"/>

            <Width val="2"/>
            <Color val="424242"/>
            <Alpha val="255"/>
        </Frame>

        <Frame type="UnitCacheFrame" name="UnitCacheFrame">
            <Anchor relative="$parent"/>
        </Frame>

        <Frame type="EditBox" name="CustomModelLink">
            <Anchor relative="$parent"/>

            <Visible val="False"/>
        </Frame>

        <Frame type="EditBox" name="SkinEntryLink">
            <Anchor relative="$parent"/>
            <Visible val="False"/>
        </Frame>
        <Frame type="EditBox" name="UnitLink">
            <Anchor relative="$parent"/>
            <Visible val="False"/>
        </Frame>
        <StateGroup name="SelectedSkin">

            <State name="None"/>
            <State name="Skin1">
                <When type="Property" frame="$parent/SkinListboxPanel/SkinButton1" Toggled="True"/>
                <Action type="SetProperty" frame="UnitCacheFrame"  Unit="{$parent/$parent/SkinListboxPanel/SkinButton1/UnitCacheFrame/@Unit}"/>
                <Action type="SetProperty" frame="CustomModelLink" Text="{$parent/$parent/SkinListboxPanel/SkinButton1/CustomModelLink/@Text}"/>
                <Action type="SetProperty" frame="SkinEntryLink"   Text="{$parent/$parent/SkinListboxPanel/SkinButton1/SkinEntryLink/@Text}"/>
                <Action type="SetState" frame="$this" group="EmptyState" state="NotEmpty"/>
            </State>
            <State name="Skin2">
                <When type="Property" frame="$parent/SkinListboxPanel/SkinButton2" Toggled="True"/>
                <Action type="SetProperty" frame="UnitCacheFrame"  Unit="{$parent/$parent/SkinListboxPanel/SkinButton2/UnitCacheFrame/@Unit}"/>
                <Action type="SetProperty" frame="CustomModelLink" Text="{$parent/$parent/SkinListboxPanel/SkinButton2/CustomModelLink/@Text}"/>
                <Action type="SetProperty" frame="SkinEntryLink"   Text="{$parent/$parent/SkinListboxPanel/SkinButton2/SkinEntryLink/@Text}"/>
                <Action type="SetState" frame="$this" group="EmptyState" state="NotEmpty"/>
            </State>
            <State name="Skin3">
                <When type="Property" frame="$parent/SkinListboxPanel/SkinButton3" Toggled="True"/>
                <Action type="SetProperty" frame="UnitCacheFrame"  Unit="{$parent/$parent/SkinListboxPanel/SkinButton3/UnitCacheFrame/@Unit}"/>
                <Action type="SetProperty" frame="CustomModelLink" Text="{$parent/$parent/SkinListboxPanel/SkinButton3/CustomModelLink/@Text}"/>
                <Action type="SetProperty" frame="SkinEntryLink"   Text="{$parent/$parent/SkinListboxPanel/SkinButton3/SkinEntryLink/@Text}"/>
                <Action type="SetState" frame="$this" group="EmptyState" state="NotEmpty"/>
            </State>
            <State name="Skin4">
                <When type="Property" frame="$parent/SkinListboxPanel/SkinButton4" Toggled="True"/>
                <Action type="SetProperty" frame="UnitCacheFrame"  Unit="{$parent/$parent/SkinListboxPanel/SkinButton4/UnitCacheFrame/@Unit}"/>
                <Action type="SetProperty" frame="CustomModelLink" Text="{$parent/$parent/SkinListboxPanel/SkinButton4/CustomModelLink/@Text}"/>
                <Action type="SetProperty" frame="SkinEntryLink"   Text="{$parent/$parent/SkinListboxPanel/SkinButton4/SkinEntryLink/@Text}"/>
                <Action type="SetState" frame="$this" group="EmptyState" state="NotEmpty"/>
            </State>
            <State name="Skin5">
                <When type="Property" frame="$parent/SkinListboxPanel/SkinButton5" Toggled="True"/>
                <Action type="SetProperty" frame="UnitCacheFrame"  Unit="{$parent/$parent/SkinListboxPanel/SkinButton5/UnitCacheFrame/@Unit}"/>
                <Action type="SetProperty" frame="CustomModelLink" Text="{$parent/$parent/SkinListboxPanel/SkinButton5/CustomModelLink/@Text}"/>
                <Action type="SetProperty" frame="SkinEntryLink"   Text="{$parent/$parent/SkinListboxPanel/SkinButton5/SkinEntryLink/@Text}"/>
                <Action type="SetState" frame="$this" group="EmptyState" state="NotEmpty"/>
            </State>
            <State name="Skin6">
                <When type="Property" frame="$parent/SkinListboxPanel/SkinButton6" Toggled="True"/>
                <Action type="SetProperty" frame="UnitCacheFrame"  Unit="{$parent/$parent/SkinListboxPanel/SkinButton6/UnitCacheFrame/@Unit}"/>
                <Action type="SetProperty" frame="CustomModelLink" Text="{$parent/$parent/SkinListboxPanel/SkinButton6/CustomModelLink/@Text}"/>
                <Action type="SetProperty" frame="SkinEntryLink"   Text="{$parent/$parent/SkinListboxPanel/SkinButton6/SkinEntryLink/@Text}"/>
                <Action type="SetState" frame="$this" group="EmptyState" state="NotEmpty"/>
            </State>
            <State name="Skin7">
                <When type="Property" frame="$parent/SkinListboxPanel/SkinButton7" Toggled="True"/>
                <Action type="SetProperty" frame="UnitCacheFrame"  Unit="{$parent/$parent/SkinListboxPanel/SkinButton7/UnitCacheFrame/@Unit}"/>
                <Action type="SetProperty" frame="CustomModelLink" Text="{$parent/$parent/SkinListboxPanel/SkinButton7/CustomModelLink/@Text}"/>
                <Action type="SetProperty" frame="SkinEntryLink"   Text="{$parent/$parent/SkinListboxPanel/SkinButton7/SkinEntryLink/@Text}"/>
                <Action type="SetState" frame="$this" group="EmptyState" state="NotEmpty"/>
            </State>
            <State name="Skin8">
                <When type="Property" frame="$parent/SkinListboxPanel/SkinButton8" Toggled="True"/>
                <Action type="SetProperty" frame="UnitCacheFrame"  Unit="{$parent/$parent/SkinListboxPanel/SkinButton8/UnitCacheFrame/@Unit}"/>
                <Action type="SetProperty" frame="CustomModelLink" Text="{$parent/$parent/SkinListboxPanel/SkinButton8/CustomModelLink/@Text}"/>
                <Action type="SetProperty" frame="SkinEntryLink"   Text="{$parent/$parent/SkinListboxPanel/SkinButton8/SkinEntryLink/@Text}"/>
                <Action type="SetState" frame="$this" group="EmptyState" state="NotEmpty"/>
            </State>
            <State name="Skin9">
                <When type="Property" frame="$parent/SkinListboxPanel/SkinButton9" Toggled="True"/>
                <Action type="SetProperty" frame="UnitCacheFrame"  Unit="{$parent/$parent/SkinListboxPanel/SkinButton9/UnitCacheFrame/@Unit}"/>
                <Action type="SetProperty" frame="CustomModelLink" Text="{$parent/$parent/SkinListboxPanel/SkinButton9/CustomModelLink/@Text}"/>
                <Action type="SetProperty" frame="SkinEntryLink"   Text="{$parent/$parent/SkinListboxPanel/SkinButton9/SkinEntryLink/@Text}"/>
                <Action type="SetState" frame="$this" group="EmptyState" state="NotEmpty"/>
            </State>
        </StateGroup>

        <Frame type="Frame" name="SkinPreviewPanel">
            <Anchor side="Left" relative="$parent" pos="Mid" offset="0"/>
            <Anchor side="Right" relative="$parent" pos="Mid" offset="0"/>
            <Anchor side="Top" relative="$parent" pos="Min" offset="40"/>

            <Width val="240"/>
            <Height val="240"/>

            <Frame type="Frame" name="AnchorFrame">
                <Anchor relative="$parent" offset="-12"/>
            </Frame>

            <Frame type="Image" name="Border">
                <Anchor relative="$parent"/>

                <Texture val="Assets\Textures\evo_ui_optionsmenu_button.dds"/>
                <TextureType val="NineSlice"/>
            </Frame>

            <Frame type="UnitModelFrame" name="UnitPreviewFrame" template="EvoClassic_StandardTemplates/UnitModelFrameTemplate">
                <Anchor relative="$parent/AnchorFrame"/>

                <UnitLink val="{$parent/$parent/UnitCacheFrame/@Unit}"/>
                <CustomModelLink val="{$parent/$parent/CustomModelLink/@Text}"/>
            </Frame>

        </Frame>

        <Frame type="Image" name="LockIcon">
            <Anchor side="Top" relative="$parent/SkinPreviewPanel/AnchorFrame" pos="Min" offset="15"/>
            <Anchor side="Bottom" relative="$this/SkinPreviewPanel/AnchorFrame" pos="Min" offset="0"/>
            <Anchor side="Right" relative="$parent/SkinPreviewPanel/AnchorFrame" pos="Max" offset="-12"/>

            <Width val="40"/>
            <Height val="40"/>
            <Texture val="Assets\Textures\ui_battlenet_glue_campaign_subselectionicon_lock.dds"/>
            <ColorAdjustMode val="Colorize"/>
            <AdjustmentColor val="207909"/>

            <StateGroup name="LockedState">
                <DefaultState val="NotLocked"/>
            
                <State name="Locked">
                    <When type="StateGroup" frame="$parent" LockedState="Locked"/>
                    <When type="StateGroup" frame="$parent" EmptyState="NotEmpty"/>
                    
                    <Action type="SetProperty" frame="$this" Visible="True"/>
                </State>
                
                <State name="NotLocked">
                    <Action type="SetProperty" frame="$this" Visible="False"/>
                </State>
            </StateGroup>
        </Frame>

        <!-- EQUIPPED ICON -->
        <Frame type="Image" name="EquippedIcon">
            <Anchor side="Top" relative="$parent/SkinPreviewPanel/AnchorFrame" pos="Min" offset="-3"/>
            <Anchor side="Bottom" relative="$parent/SkinPreviewPanel/AnchorFrame" pos="Max" offset="3"/>
            <Anchor side="Left" relative="$parent/SkinPreviewPanel/AnchorFrame" pos="Min" offset="-3"/>
            <Anchor side="Right" relative="$parent/SkinPreviewPanel/AnchorFrame" pos="Max" offset="3"/>

            <Texture val="@UI/Glues_Battlenet_PageAssets_GraphicListItem_Border_Equipped"/>
            <TextureType val="NineSlice"/>

            <StateGroup name="VisibleState">
                <DefaultState val="NotVisible"/>
            
                <State name="Visible">
                    <When type="StateGroup" frame="$parent" EmptyState="NotEmpty"/>
                    <When type="StateGroup" frame="$parent" EquippedState="Equipped"/>
                    <Action type="SetProperty" frame="$this" Visible="True"/>
                </State>
                
                <State name="NotVisible">
                    <Action type="SetProperty" frame="$this" Visible="False"/>
                </State>
            </StateGroup>
        </Frame>

        <Frame type="Label" name="PreviewHeader">
            <Anchor side="Top" relative="$parent/SkinPreviewPanel" pos="Max" offset="20"/>
            <Anchor side="Left" relative="$parent" pos="Min" offset="5"/>
            <Anchor side="Right" relative="$parent" pos="Max" offset="-5"/>

            <Style val="Evo_Skins_PreviewHeader"/>
            <Text val="{TTF/@Text}"/>
            <Frame type="TextFormatFrame" name="TTF">
                <Replacement val="{$parent/$parent/SkinEntryLink/@Text}"/>
                <FormatText val="&lt;d stringref=&quot;Skin,%0%,Name&quot;/&gt;"/>
            </Frame>
        </Frame>

        <Frame type="Label" name="PreviewDescription">
            <Anchor side="Top" relative="$parent/PreviewHeader" pos="Max" offset="5"/>
            <Anchor side="Left" relative="$parent" pos="Min" offset="20"/>
            <Anchor side="Right" relative="$parent" pos="Max" offset="-20"/>

            <Style val="Evo_Skins_PreviewDescription"/>
            <Text val="{TTF/@Text}"/>
            <Frame type="TextFormatFrame" name="TTF">
                <Replacement val="{$parent/$parent/SkinEntryLink/@Text}"/>
                <FormatText val="&lt;d stringref=&quot;Skin,%0%,InfoText&quot;/&gt;"/>
            </Frame>
        </Frame>
        
        <Frame type="Frame" name="UnlockCriteriaPanel">
            <Anchor side="Top" relative="$parent/PreviewDescription" pos="Max" offset="80"/>
            <Anchor side="Left" relative="$parent" pos="Min" offset="15"/>
            <Anchor side="Right" relative="$parent" pos="Max" offset="-15"/>

            <Height val="80"/>
            <Visible val="False"/>

            <Frame type="Label" name="UnlockLabel">
                <Anchor side="Top" relative="$parent" pos="Min" offset="0"/>
                <Anchor side="Left" relative="$parent" pos="Min" offset="10"/> 
                <Anchor side="Right" relative="$parent" pos="Max" offset="-10"/>

                <Text val="Unlock Progress"/>
                <Style val="Evo_Skins_PreviewUnlockLabel"/>
            </Frame>

            <Frame type="Image" name="ProgressBarBackground" template="EvoClassic_StandardTemplates/ProgressBarBackgroundTemplate">
                <Anchor side="Top" relative="$parent/UnlockLabel" pos="Max" offset="5"/>
                <Anchor side="Left" relative="$parent" pos="Min" offset="5"/>
                <Anchor side="Right" relative="$parent" pos="Max" offset="-5"/>

                <Height val="22"/>
            </Frame>

            <Frame type="ProgressBar" name="ProgressBar" template="EvoClassic_StandardTemplates/StandardProgressBarTemplate">
                <Anchor relative="$parent/ProgressBarBackground" offset="-4"/>

                <Value val="100"/>
                <MaxValue val="500"/>
            </Frame>
        </Frame>

        <Frame type="Button" name="EquipButton" template="EvoClassic_SkinsMenuTemplates/EquipButtonTemplate">
            <Anchor side="Bottom" relative="$parent" pos="Max" offset="-25"/>
            <Anchor side="Left" relative="$parent" pos="Min" offset="25"/>
            <Anchor side="Right" relative="$parent" pos="Max" offset="-25"/>

            <Height val="50"/>
            <Style val="Evo_Options_DifficultyPresetButton"/>
        </Frame>

                
        <!--
        ===============
        STATEGROUPS
        ===============
        -->
                
        <!-- EmptyState -->
        <StateGroup name="EmptyState">
            <DefaultState val="Empty"/>
            <State name="Empty">
                <!--When type="AnimationState" frame="$this" EmptyState="Empty"/-->
                <!--When type="Property" frame="$this/UnitLink" Text=""/-->
            </State>
            <State name="NotEmpty"/>
        </StateGroup>
                
        <!-- SelectedState -->
        <StateGroup name="SelectedState">
            <DefaultState val="NotSelected"/>
            <State name="Selected">
                <When type="Property" frame="$this" Toggled="True"/>
                <Action type="SetProperty" frame="$this" RenderPriority="515"/>
            </State>
            <State name="NotSelected">
                <When type="Property" frame="$this" Toggled="False"/>
                <Action type="SetProperty" frame="$this" RenderPriority="512"/>
            </State>
        </StateGroup>
                
        <!-- HoveredState -->
        <StateGroup name="HoveredState">
            <DefaultState val="NotHovered"/>
            <State name="Hovered">
                <When type="Property" frame="$this" Hovering="True"/>
            </State>
            <State name="NotHovered"/>
        </StateGroup>
                
        <!-- LockedState -->
        <StateGroup name="LockedState">
            <DefaultState val="NotLocked"/>
            <State name="Locked">
                <When type="AnimationState" frame="$this" LockedState="Locked"/>
            </State>
            <State name="NotLocked">
                <When type="AnimationState" frame="$this" LockedState="NotLocked"/>
            </State>
        </StateGroup>
                
        <!-- EquippedState -->
        <StateGroup name="EquippedState">
            <DefaultState val="NotEquipped"/>
            <State name="Equipped">
                <When type="AnimationState" frame="$this" EquippedState="Equipped"/>
            </State>
            <State name="NotEquipped">
                <When type="AnimationState" frame="$this" EquippedState="NotEquipped"/>
            </State>
        </StateGroup>
                
        <!-- PurchasableState -->
        <StateGroup name="PurchasableState">
            <DefaultState val="NotPurchasable"/>
            <State name="Purchasable">
            </State>
            <State name="NotPurchasable">
            </State>
        </StateGroup>
        
        <!-- ExternalState -->
        <StateGroup name="ExternalState">
            <DefaultState val="NotExternal"/>
            <State name="External"/>
            <State name="NotExternal"/>
        </StateGroup>
    </Frame>

