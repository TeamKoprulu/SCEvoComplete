            <State name="NotEmpty"/>
        </StateGroup>
                
        <!-- SelectedState -->
        <StateGroup name="SelectedState">
            <DefaultState val="NotSelected"/>
            <State name="Selected">
                <When type="Property" frame="$this" Toggled="True"/>
                <Action type="SetProperty" frame="$this" RenderPriority="515"/>
            </State>
            <State name="NotSelected">
                <When type="Property" frame="$this" Toggled="False"/>
                <Action type="SetProperty" frame="$this" RenderPriority="512"/>
            </State>
        </StateGroup>
                
        <!-- HoveredState -->
        <StateGroup name="HoveredState">
