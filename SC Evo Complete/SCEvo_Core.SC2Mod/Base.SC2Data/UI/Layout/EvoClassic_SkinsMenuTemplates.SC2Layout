    <!-- Main Panel Template -->

    <Frame type="Frame" name="SkinsPanelTemplate">

        <Frame type="Label" name="Header">
            <Anchor side="Top" relative="$parent" pos="Min" offset="5"/>
            <Anchor side="Left" relative="$parent" pos="Mid" offset="0"/>
            <Anchor side="Right" relative="$parent" pos="Mid" offset="0"/>
            <Width val="450"/>
            <Height val="65"/>
            <Style val="Evo_Options_DifficultyHeader"/>
            <Text val="@UI/Classic/OptionsMenu/SkinsHeader"/>
            <Tooltip val="@UI/Classic/OptionsMenu/SkinsHeaderTip"/>
            <TooltipFrame val="OptionsMenuTooltip"/>
            <TooltipAnchorPosition val="TopCenter"/>
            <AcceptsMouse val="True"/>
        </Frame>

        <!-- Race Tab Control -->

        <Frame type="TabControl" name="RaceTabControl">
            <TabListItem val="$parent/TerranButton"/>
            <TabListItem val="$parent/ProtossButton"/>
            <TabListItem val="$parent/ZergButton"/> 
        </Frame>

        <!-- Race Buttons -->
         
        <Frame type="Button" name="TerranButton" template="EvoClassic_SkinsMenuTemplates/SkinsRaceButtonTemplate">
            <Anchor side="Top" relative="$parent/ProtossButton" pos="Min" offset="0"/>
            <Anchor side="Right" relative="$parent/ProtossButton" pos="Min" offset="-34"/>
            <Text val="@UI/Race/Terran"/>

            <StateGroup name="ToggleState">
                <State name="Default">

                </State>

                <State name="Toggled">
                    <When type="Property" frame="$this" Toggled="True"/>

                    <Action type="SetProperty" frame="$this" AcceptsMouse="False" on="Enter"/>
                    <Action type="SetProperty" frame="$this" AcceptsMouse="True" on="Exit"/>

                    <Action type="SetProperty" frame="$this/NormalImage" LightAdjustColor="8eff8e"/>
                    <Action type="SetProperty" frame="$this/NormalImage" DarkAdjustColor="8eff8e"/>
                    <Action type="SetProperty" frame="$this/HoverImage" LightAdjustColor="8eff8e"/>
                    <Action type="SetProperty" frame="$this/HoverImage" DarkAdjustColor="8eff8e"/>
                    <Action type="SetProperty" frame="$this" Style="Evo_Skins_Race_Terran"/>
                </State>
            </StateGroup>
        </Frame>

        <Frame type="Button" name="ProtossButton" template="EvoClassic_SkinsMenuTemplates/SkinsRaceButtonTemplate">
            <Anchor side="Top" relative="$parent" pos="Min" offset="80"/>
            <Anchor side="Right" relative="$parent" pos="Mid" offset="0"/>
            <Anchor side="Left" relative="$parent" pos="Mid" offset="0"/>
            <Text val="@UI/Race/Protoss"/>

            <StateGroup name="ToggleState">
                <State name="Default">

                </State>

                <State name="Toggled">
                    <When type="Property" frame="$this" Toggled="True"/>

                    <Action type="SetProperty" frame="$this" AcceptsMouse="False" on="Enter"/>
                    <Action type="SetProperty" frame="$this" AcceptsMouse="True" on="Exit"/>

                    <Action type="SetProperty" frame="$this/NormalImage" LightAdjustColor="0099ff"/>
                    <Action type="SetProperty" frame="$this/NormalImage" DarkAdjustColor="0099ff"/>
                    <Action type="SetProperty" frame="$this/HoverImage" LightAdjustColor="0099ff"/>
                    <Action type="SetProperty" frame="$this/HoverImage" DarkAdjustColor="0099ff"/>
                    <Action type="SetProperty" frame="$this" Style="Evo_Skins_Race_Protoss"/>
                </State>
            </StateGroup>
        </Frame>

        <Frame type="Button" name="ZergButton" template="EvoClassic_SkinsMenuTemplates/SkinsRaceButtonTemplate">
            <Anchor side="Top" relative="$parent/ProtossButton" pos="Min" offset="0"/>
            <Anchor side="Left" relative="$parent/ProtossButton" pos="Max" offset="34"/>
            <Text val="@UI/Race/Zerg"/>

            <StateGroup name="ToggleState">
                <State name="Default">

                </State>

                <State name="Toggled">
                    <When type="Property" frame="$this" Toggled="True"/>

                    <Action type="SetProperty" frame="$this" AcceptsMouse="False" on="Enter"/>
                    <Action type="SetProperty" frame="$this" AcceptsMouse="True" on="Exit"/>

                    <Action type="SetProperty" frame="$this/NormalImage" LightAdjustColor="ae00ff"/>
                    <Action type="SetProperty" frame="$this/NormalImage" DarkAdjustColor="ae00ff"/>
                    <Action type="SetProperty" frame="$this/HoverImage" LightAdjustColor="ae00ff"/>
                    <Action type="SetProperty" frame="$this/HoverImage" DarkAdjustColor="ae00ff"/>
                    <Action type="SetProperty" frame="$this" Style="Evo_Skins_Race_Zerg"/>
                </State>
            </StateGroup>
        </Frame>

        <Animation name="TabToggleReset">
            <Event event="OnClick" action="Reset,Play" frame="$this/TerranButton"/>
            <Event event="OnClick" action="Reset,Play" frame="$this/ProtossButton"/>
            <Event event="OnClick" action="Reset,Play" frame="$this/ZergButton"/>

            <Controller type="Property" end="Pause" frame="$this/UnitListboxPanel/ScrollableFrame/ContainerFrame/TabControl" property="SelectedIndex">
                <Key type="Property" time="0.0" value="0"/>
                <Key type="Property" time="0.001" value="0"/>
            </Controller>

            <Controller type="Property" end="Pause" frame="$this/SkinListboxPanel/TabControl" property="SelectedIndex">
                <Key type="Property" time="0.0" value="0"/>
                <Key type="Property" time="0.001" value="0"/>
            </Controller>
        </Animation>

        <Animation name="SkinToggleReset">
            <Event event="OnClick" action="Reset,Play" frame="$this/UnitListboxPanel/ScrollableFrame/ContainerFrame/ListboxItem1"/>
            <Event event="OnClick" action="Reset,Play" frame="$this/UnitListboxPanel/ScrollableFrame/ContainerFrame/ListboxItem2"/>
            <Event event="OnClick" action="Reset,Play" frame="$this/UnitListboxPanel/ScrollableFrame/ContainerFrame/ListboxItem3"/>
            <Event event="OnClick" action="Reset,Play" frame="$this/UnitListboxPanel/ScrollableFrame/ContainerFrame/ListboxItem4"/>
            <Event event="OnClick" action="Reset,Play" frame="$this/UnitListboxPanel/ScrollableFrame/ContainerFrame/ListboxItem5"/>
            <Event event="OnClick" action="Reset,Play" frame="$this/UnitListboxPanel/ScrollableFrame/ContainerFrame/ListboxItem6"/>
            <Event event="OnClick" action="Reset,Play" frame="$this/UnitListboxPanel/ScrollableFrame/ContainerFrame/ListboxItem7"/>
            <Event event="OnClick" action="Reset,Play" frame="$this/UnitListboxPanel/ScrollableFrame/ContainerFrame/ListboxItem8"/>
            <Event event="OnClick" action="Reset,Play" frame="$this/UnitListboxPanel/ScrollableFrame/ContainerFrame/ListboxItem9"/>
            <Event event="OnClick" action="Reset,Play" frame="$this/UnitListboxPanel/ScrollableFrame/ContainerFrame/ListboxItem10"/>
            <Event event="OnClick" action="Reset,Play" frame="$this/UnitListboxPanel/ScrollableFrame/ContainerFrame/ListboxItem11"/>
            <Event event="OnClick" action="Reset,Play" frame="$this/UnitListboxPanel/ScrollableFrame/ContainerFrame/ListboxItem12"/>
            <Event event="OnClick" action="Reset,Play" frame="$this/UnitListboxPanel/ScrollableFrame/ContainerFrame/ListboxItem13"/>
            <Event event="OnClick" action="Reset,Play" frame="$this/UnitListboxPanel/ScrollableFrame/ContainerFrame/ListboxItem14"/>

            <Controller type="Property" end="Pause" frame="$this/SkinListboxPanel/TabControl" property="SelectedIndex">
                <Key type="Property" time="0.0" value="0"/>
                <Key type="Property" time="0.001" value="0"/>
            </Controller>
        </Animation>

        <Frame type="Image" name="Divider">
            <Anchor side="Top" relative="$parent/ProtossButton" pos="Max" offset="25"/>
            <Anchor side="Left" relative="$parent" pos="Min" offset="50"/>
            <Width val="1100"/>
            <Height val="2"/>
            <Color val="6C0000"/>
            <Alpha val="255"/>
        </Frame>

        <!-- Listbox Panels -->

        <Frame type="Frame" name="UnitListboxPanel" template="EvoClassic_SkinsMenuTemplates/UnitListboxTemplate">
        </Frame>

        <!-- Shared Panels -->

        <Frame type="Frame" name="SkinListboxPanel">
            <Anchor side="Top" relative="$parent/Divider" pos="Max" offset="0"/>
            <Anchor side="Bottom" relative="$parent" pos="Max" offset="0"/>
            <Anchor side="Left" relative="$parent/UnitListboxPanel" pos="Max" offset="0"/>
            <Anchor side="Right" relative="$parent/PreviewPanel" pos="Min" offset="0"/>

            <Frame type="TabControl" name="TabControl">
                <TabListItem val="$parent/SkinButton1"/>
                <TabListItem val="$parent/SkinButton2"/>
                <TabListItem val="$parent/SkinButton3"/>
                <TabListItem val="$parent/SkinButton4"/>
                <TabListItem val="$parent/SkinButton5"/>
                <TabListItem val="$parent/SkinButton6"/>
                <TabListItem val="$parent/SkinButton7"/>
                <TabListItem val="$parent/SkinButton8"/>
                <TabListItem val="$parent/SkinButton9"/>

                <SelectedIndex val="0"/>
            </Frame>

            <Frame type="Button" name="SkinButton1" template="EvoClassic_SkinsMenuTemplates/UnitSkinControlTemplate">
                <Anchor side="Top" relative="$parent" pos="Min" offset="50"/>
                <Anchor side="Left" relative="$parent" pos="Min" offset="50"/>
            </Frame>

            <Frame type="Button" name="SkinButton2" template="EvoClassic_SkinsMenuTemplates/UnitSkinControlTemplate">
                <Anchor side="Top" relative="$parent/SkinButton1" pos="Min" offset="0"/>
                <Anchor side="Left" relative="$parent/SkinButton1" pos="Max" offset="20"/>
            </Frame>

            <Frame type="Button" name="SkinButton3" template="EvoClassic_SkinsMenuTemplates/UnitSkinControlTemplate">
                <Anchor side="Top" relative="$parent/SkinButton2" pos="Min" offset="0"/>
                <Anchor side="Left" relative="$parent/SkinButton2" pos="Max" offset="20"/>
            </Frame>

            <Frame type="Button" name="SkinButton4" template="EvoClassic_SkinsMenuTemplates/UnitSkinControlTemplate">
                <Anchor side="Top" relative="$parent/SkinButton1" pos="Max" offset="20"/>
                <Anchor side="Left" relative="$parent/SkinButton1" pos="Min" offset="0"/>
            </Frame>

            <Frame type="Button" name="SkinButton5" template="EvoClassic_SkinsMenuTemplates/UnitSkinControlTemplate">
                <Anchor side="Top" relative="$parent/SkinButton4" pos="Min" offset="0"/>
                <Anchor side="Left" relative="$parent/SkinButton4" pos="Max" offset="20"/>
            </Frame>

            <Frame type="Button" name="SkinButton6" template="EvoClassic_SkinsMenuTemplates/UnitSkinControlTemplate">
                <Anchor side="Top" relative="$parent/SkinButton4" pos="Min" offset="0"/>
                <Anchor side="Left" relative="$parent/SkinButton5" pos="Max" offset="20"/>
            </Frame>

            <Frame type="Button" name="SkinButton7" template="EvoClassic_SkinsMenuTemplates/UnitSkinControlTemplate">
                <Anchor side="Top" relative="$parent/SkinButton4" pos="Max" offset="20"/>
                <Anchor side="Left" relative="$parent/SkinButton1" pos="Min" offset="0"/>
            </Frame>

            <Frame type="Button" name="SkinButton8" template="EvoClassic_SkinsMenuTemplates/UnitSkinControlTemplate">
                <Anchor side="Top" relative="$parent/SkinButton7" pos="Min" offset="0"/>
                <Anchor side="Left" relative="$parent/SkinButton7" pos="Max" offset="20"/>
            </Frame>

            <Frame type="Button" name="SkinButton9" template="EvoClassic_SkinsMenuTemplates/UnitSkinControlTemplate">
                <Anchor side="Top" relative="$parent/SkinButton7" pos="Min" offset="0"/>
                <Anchor side="Left" relative="$parent/SkinButton8" pos="Max" offset="20"/>
            </Frame>
        </Frame>



        <Frame type="Frame" name="PreviewPanel" template="EvoClassic_SkinsMenuTemplates/SkinPreviewPanelTemplate">
            <Handle val="SkinsPreviewPanel"/>
        </Frame>
    </Frame>

    <Frame type="Frame" name="CollectionsPanelTemplate">
        <Frame type="Label" name="Header">
            <Anchor side="Top" relative="$parent" pos="Min" offset="5"/>
            <Anchor side="Left" relative="$parent" pos="Mid" offset="0"/>
            <Anchor side="Right" relative="$parent" pos="Mid" offset="0"/>
            <Width val="450"/>
            <Height val="65"/>
            <Style val="Evo_Options_DifficultyHeader"/>
            <Text val="@UI/Classic/OptionsMenu/CollectionsHeader"/>
            <!-- <Tooltip val="@UI/Classic/OptionsMenu/CollectionsHeaderTip"/> -->
            <TooltipFrame val="OptionsMenuTooltip"/>
            <TooltipAnchorPosition val="TopCenter"/>
            <AcceptsMouse val="True"/>
        </Frame>

        <Frame type="Image" name="Divider">
            <Anchor side="Top" relative="$parent/Header" pos="Max" offset="94"/>
            <Anchor side="Left" relative="$parent" pos="Min" offset="50"/>
            <Width val="1100"/>
            <Height val="2"/>
            <Color val="6C0000"/>
            <Alpha val="255"/>
        </Frame>

        <!-- Collections Listbox Panel -->

        <Frame type="ScrollableFrame" name="CollectionsListboxPanel">
            <Anchor side="Top" relative="$parent/Divider" pos="Max" offset="15"/>
            <Anchor side="Bottom" relative="$parent" pos="Max" offset="-15"/>
            <Anchor side="Left" relative="$parent" pos="Min" offset="15"/>
            <Anchor side="Right" relative="$parent/PreviewPanel" pos="Min" offset="-15"/>

            <AcceptsMouse val="true"/>

            <Frame type="Frame" name="ContainerFrame">
                <Anchor side="Top" relative="$parent" pos="Min" offset="0"/>
                <Anchor side="Left" relative="$parent" pos="Min" offset="0"/>
                <Anchor side="Bottom" relative="$parent/ContainerFrameBottomAnchor" pos="Min" offset="0"/>
                <Anchor side="Right" relative="$parent/ScrollBarBackground" pos="Min" offset="0"/>

                <Frame type="TabControl" name="TabControl">
                    <TabListItem val="$parent/CategoryContainer1/ListboxItem1"/>
                    <TabListItem val="$parent/CategoryContainer1/ListboxItem2"/>
                    <TabListItem val="$parent/CategoryContainer2/ListboxItem1"/>
                    <TabListItem val="$parent/CategoryContainer2/ListboxItem2"/>
                </Frame>

                <Frame type="Frame" name="CategoryContainer1" template="EvoClassic_SkinsMenuTemplates/CollectionCategoryTemplate">
                    <Anchor side="Top" relative="$parent" pos="Min" offset="0"/>
                    <Anchor side="Left" relative="$parent" pos="Min" offset="0"/>
                    <Anchor side="Right" relative="$parent" pos="Max" offset="0"/>
                    <Anchor side="Bottom" relative="$this/ListboxItem1" pos="Max" offset="10"/>

                    <Frame type="Label" name="CategoryHeaderLabel">
                        <Text val="Resource Skins"/>
                    </Frame>
                </Frame>

                <Frame type="Frame" name="CategoryContainer2" template="EvoClassic_SkinsMenuTemplates/CollectionCategoryTemplate">
                    <Anchor side="Top" relative="$sibling-1" pos="max" offset="30"/>
                    <Anchor side="Left" relative="$parent" pos="Min" offset="0"/>
                    <Anchor side="Right" relative="$parent" pos="Max" offset="0"/>
                    <Anchor side="Bottom" relative="$this/ListboxItem1" pos="Max" offset="10"/>

                    <Frame type="Label" name="CategoryHeaderLabel">
                        <Text val="Resource Skins"/>
                    </Frame>
                </Frame>
            </Frame>

            <Frame type="Image" name="ScrollBarBackground" template="EvoClassic_StandardTemplates/ScrollBarBackgroundTemplate">
                <Visible val="{$parent/ScrollBar/@Visible}"/>
                <CollapseLayout val="True"/>
            </Frame>
        
            <Frame type="ScrollBar" name="ScrollBar" template="EvoClassic_StandardTemplates/ScrollBarTemplate">
                <Anchor side="Top" relative="$parent" pos="Min" offset="0"/>
                <Anchor side="Bottom" relative="$parent" pos="Max" offset="-15"/>
                <Anchor side="Right" relative="$parent" pos="Max" offset="-12"/>
            </Frame>

            <Frame type="Frame" name="ContainerFrameBottomAnchor">
                <Anchor side="Bottom" relative="$parent/ContainerFrame/CategoryContainer2" pos="Max" offset="0"/>
                <Anchor side="Left" relative="$parent" pos="Min" offset="0"/>
                <Anchor side="Right" relative="$parent" pos="Max" offset="0"/>
                <Height val="1"/>
            </Frame>
        </Frame>

        <!-- Preview Panel -->

        <Frame type="Frame" name="PreviewPanel" template="EvoClassic_SkinsMenuTemplates/CollectionPreviewPanelTemplate">
            <Handle val="CollectionPreviewPanel"/>
        </Frame>
    </Frame>
</Desc>